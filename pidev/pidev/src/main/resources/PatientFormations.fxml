<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.PatientFormationsController"
      fx:id="rootContainer" spacing="0"
      style="-fx-background-color:#F2F0EC;">

    <HBox alignment="CENTER_LEFT" spacing="15"
          style="-fx-padding:22 30;-fx-background-color:white;
                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
        <VBox spacing="3">
            <Label text="📚 Formations Disponibles"
                   style="-fx-font-size:22px;-fx-font-weight:700;-fx-text-fill:#2D3748;"/>
            <Label fx:id="lblCount" text="Chargement..."
                   style="-fx-font-size:12px;-fx-text-fill:#718096;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="tfSearch" promptText="🔍 Rechercher..."
                   prefWidth="240"
                   style="-fx-background-color:#F7FAFC;-fx-border-color:#E2E8F0;
                          -fx-border-radius:8;-fx-background-radius:8;
                          -fx-border-width:1.5;-fx-padding:9 14;-fx-font-size:13px;"/>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                style="-fx-background:transparent;-fx-background-color:transparent;">
        <FlowPane fx:id="cardsPane" hgap="15" vgap="15"
                  style="-fx-padding:25 30;">
        </FlowPane>
    </ScrollPane>
</VBox>