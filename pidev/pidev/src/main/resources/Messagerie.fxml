<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<HBox spacing="0" VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.Messageriecontroller"
      style="-fx-background-color: #F2F0EC;">

    <!-- ── Left: Conversations list ── -->
    <VBox prefWidth="300" minWidth="260"
          style="-fx-background-color: white;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 2, 0);">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 20 20; -fx-background-color: white;
                     -fx-border-color: transparent transparent #F0EDE8 transparent; -fx-border-width: 1;">
            <StackPane prefWidth="36" prefHeight="36">
                <Circle radius="18" fill="#4A6FA5"/>
                <Label text="💬" style="-fx-font-size: 16px;"/>
            </StackPane>
            <VBox spacing="2">
                <Label text="Messagerie"
                       style="-fx-font-size: 16px; -fx-font-weight: 700; -fx-text-fill: #2D3748;"/>
                <Label text="Vos conversations"
                       style="-fx-font-size: 10px; -fx-text-fill: #A0AEC0;"/>
            </VBox>
        </HBox>

        <!-- Search -->
        <HBox style="-fx-padding: 12 16;">
            <TextField promptText="🔍  Rechercher..."
                       maxWidth="Infinity" HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #F7F5F2; -fx-border-color: #E8E4DF;
                              -fx-border-radius: 20; -fx-background-radius: 20;
                              -fx-border-width: 1.5; -fx-padding: 8 14; -fx-font-size: 12px;"/>
        </HBox>

        <!-- Contacts list -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox fx:id="conversationsList" spacing="0"/>
        </ScrollPane>
    </VBox>

    <!-- ── Right: Chat area ── -->
    <VBox HBox.hgrow="ALWAYS" spacing="0">

        <!-- No conversation placeholder -->
        <VBox fx:id="lblNoConv" alignment="CENTER" spacing="15" VBox.vgrow="ALWAYS"
              style="-fx-padding: 60;">
            <Label text="💬" style="-fx-font-size: 60px;"/>
            <Label text="Sélectionnez une conversation"
                   style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #2D3748;"/>
            <Label text="Choisissez un contact à gauche pour commencer à discuter"
                   style="-fx-font-size: 13px; -fx-text-fill: #A0AEC0;" wrapText="true"/>
        </VBox>

        <!-- Chat header -->
        <VBox fx:id="chatPane" visible="false" spacing="0" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="14"
                  style="-fx-padding: 16 24; -fx-background-color: white;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);">
                <StackPane prefWidth="44" prefHeight="44">
                    <Circle radius="22" fill="#4A6FA5"/>
                    <Label fx:id="lblContactInitial"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 700;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="lblContactName" text="Contact"
                           style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #2D3748;"/>
                    <Label fx:id="lblContactRole" text="Rôle"
                           style="-fx-font-size: 10px; -fx-text-fill: #A0AEC0;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Circle radius="5" fill="#52B788"/>
                <Label text="En ligne" style="-fx-font-size: 11px; -fx-text-fill: #52B788;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Bouton Appel -->
                <StackPane prefWidth="40" prefHeight="40" style="-fx-cursor: hand;"
                           onMouseClicked="#handleCall">
                    <Circle radius="20" fill="#EBF4FF"/>
                    <Label text="📞" style="-fx-font-size: 18px;"/>
                </StackPane>
            </HBox>

            <!-- Messages scroll area -->
            <ScrollPane fx:id="scrollMessages" fitToWidth="true" hbarPolicy="NEVER"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background: #F7F5F2; -fx-background-color: #F7F5F2;">
                <VBox fx:id="messagesContainer" spacing="6"
                      style="-fx-padding: 16 0; -fx-background-color: #F7F5F2;"/>
            </ScrollPane>
        </VBox>

        <!-- Input bar -->
        <HBox fx:id="inputBar" visible="false" spacing="10" alignment="CENTER"
              style="-fx-padding: 12 18; -fx-background-color: white;
                     -fx-border-color: #F0EDE8 transparent transparent transparent; -fx-border-width: 1;">
            <TextField fx:id="tfMessage" promptText="Écrivez votre message..."
                       HBox.hgrow="ALWAYS"
                       onKeyPressed="#onEnterPressed"
                       style="-fx-background-color: #F7F5F2; -fx-border-color: #E8E4DF;
                              -fx-border-radius: 22; -fx-background-radius: 22;
                              -fx-border-width: 1.5; -fx-padding: 11 18; -fx-font-size: 13px;"/>
            <Button text="Envoyer  ➤" onAction="#sendMessage"
                    style="-fx-background-color: #4A6FA5; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: 600;
                           -fx-padding: 11 20; -fx-background-radius: 22; -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(74,111,165,0.3), 8, 0, 0, 2);"/>
        </HBox>
    </VBox>
</HBox>
