<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.PatientController"
            prefWidth="1100" prefHeight="700"
            style="-fx-background-color: #fef0f5;">

    <top>
        <HBox alignment="CENTER_RIGHT" spacing="15"
              style="-fx-background-color: linear-gradient(to right, #e8a0bf, #7fc8f8);
                     -fx-padding: 12 20;">
            <Label text="🏥 EchoCare"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"
                   HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Label text="👤" style="-fx-font-size: 20px;"/>
            <Label fx:id="lblPatientName" text="Patient"
                   style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="5" prefWidth="230"
              style="-fx-background-color: linear-gradient(to bottom, #2d3436, #3d3d3d);">
            <padding><Insets top="20" bottom="20" left="10" right="10"/></padding>

            <Label text="🏥" style="-fx-font-size: 40px;" alignment="CENTER"
                   maxWidth="Infinity"/>
            <Label text="EchoCare"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e8a0bf;"
                   alignment="CENTER" maxWidth="Infinity"/>
            <Separator style="-fx-background-color: #636e72;"/>

            <Label text="MON ESPACE"
                   style="-fx-text-fill: #636e72; -fx-font-size: 11px;
                          -fx-padding: 10 0 5 15;"/>

            <Button fx:id="btnAccueil" text="   🏠  Accueil"
                    onAction="#showAccueil"
                    styleClass="sidebar-btn" maxWidth="Infinity" alignment="CENTER_LEFT"/>

            <Button fx:id="btnAllFormations" text="   📚  Toutes les Formations"
                    onAction="#showAllFormations"
                    styleClass="sidebar-btn" maxWidth="Infinity" alignment="CENTER_LEFT"/>

            <Button fx:id="btnMyFormations" text="   📖  Mes Formations"
                    onAction="#showMyFormations"
                    styleClass="sidebar-btn" maxWidth="Infinity" alignment="CENTER_LEFT"/>

            <Button fx:id="btnMyResults" text="   📊  Mes Résultats"
                    onAction="#showMyResults"
                    styleClass="sidebar-btn" maxWidth="Infinity" alignment="CENTER_LEFT"/>

            <Separator style="-fx-background-color: #636e72;"/>

            <Label text="AUTRE"
                   style="-fx-text-fill: #636e72; -fx-font-size: 11px;
                          -fx-padding: 10 0 5 15;"/>

            <Button fx:id="btnJournal" text="   📰  Mon Journal"
                    onAction="#showJournal"
                    styleClass="sidebar-btn" maxWidth="Infinity" alignment="CENTER_LEFT"/>

            <Button fx:id="btnConsultation" text="   🩺  Mes Consultations"
                    onAction="#showConsultation"
                    styleClass="sidebar-btn" maxWidth="Infinity" alignment="CENTER_LEFT"/>

            <VBox VBox.vgrow="ALWAYS"/>

            <Separator style="-fx-background-color: #636e72;"/>

            <Button text="   👁️  Vue Admin (Test)"
                    onAction="#switchToAdmin"
                    styleClass="sidebar-btn" maxWidth="Infinity" alignment="CENTER_LEFT"/>

            <Button text="   🚪  Déconnexion" onAction="#handleLogout"
                    styleClass="sidebar-btn-logout" maxWidth="Infinity"
                    alignment="CENTER_LEFT"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #fef0f5;">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
        </StackPane>
    </center>

</BorderPane>