<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.CoachPatientsController"
      spacing="0" style="-fx-background-color:#F2F0EC;">

    <HBox alignment="CENTER_LEFT" spacing="15"
          style="-fx-padding:22 30;-fx-background-color:white;
                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
        <VBox spacing="3">
            <Label text="👥 Suivi des Patients"
                   style="-fx-font-size:22px;-fx-font-weight:700;-fx-text-fill:#2D3748;"/>
            <Label fx:id="lblCount" text="Chargement..."
                   style="-fx-font-size:12px;-fx-text-fill:#718096;"/>
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                style="-fx-background:transparent;-fx-background-color:transparent;">
        <VBox fx:id="patientsList" spacing="10" style="-fx-padding:25 30;"/>
    </ScrollPane>
</VBox>