<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.SignUp"
           prefHeight="750" prefWidth="1100"
           style="-fx-background-color: #F2D0BC;">

    <!-- Background orbs -->
    <Circle radius="320" fill="#4A6FA5" opacity="0.10" translateX="-420" translateY="-140"/>
    <Circle radius="260" fill="#E8956D" opacity="0.10" translateX="400" translateY="200"/>
    <Circle radius="140" fill="#F5C87A" opacity="0.13" translateX="100" translateY="-260"/>

    <HBox alignment="CENTER" maxWidth="920" maxHeight="620">

        <!-- ── GAUCHE : Branding ── -->
        <VBox prefWidth="340" prefHeight="620" alignment="CENTER" spacing="0"
              style="-fx-background-color: #4A6FA5; -fx-background-radius: 22 0 0 22; -fx-padding: 50 38;">

            <!-- Logo -->
            <StackPane alignment="CENTER" style="-fx-padding: 0 0 20 0;" prefWidth="80" prefHeight="80">
                <Circle radius="22" fill="#3D5A8A" translateX="-16" translateY="-2"/>
                <Circle radius="22" fill="#F5C87A" translateX="16"  translateY="-2"/>
                <Circle radius="4" fill="white" translateX="-20" translateY="-6"/>
                <Circle radius="4" fill="white" translateX="-10" translateY="-6"/>
                <Circle radius="4" fill="white" translateX="10"  translateY="-6"/>
                <Circle radius="4" fill="white" translateX="20"  translateY="-6"/>
            </StackPane>

            <Label text="EchoCare"
                   style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: white;"/>
            <Label text="Rejoignez notre plateforme"
                   style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.7); -fx-padding: 6 0 28 0;"/>

            <!-- Steps -->
            <VBox spacing="10"
                  style="-fx-background-color: rgba(255,255,255,0.12); -fx-background-radius: 14; -fx-padding: 20;">
                <Label text="INSCRIPTION EN 3 ÉTAPES"
                       style="-fx-font-size: 9px; -fx-letter-spacing: 2; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-weight: 600;"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane prefWidth="26" prefHeight="26">
                        <Circle radius="13" fill="#E8956D"/>
                        <Label text="1" style="-fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 12px;"/>
                    </StackPane>
                    <Label text="Informations personnelles"
                           style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: 600;"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane prefWidth="26" prefHeight="26">
                        <Circle radius="13" fill="rgba(255,255,255,0.2)"/>
                        <Label text="2" style="-fx-text-fill: white; -fx-font-size: 12px;"/>
                    </StackPane>
                    <Label text="Identifiants de connexion"
                           style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 12px;"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane prefWidth="26" prefHeight="26">
                        <Circle radius="13" fill="rgba(255,255,255,0.2)"/>
                        <Label text="3" style="-fx-text-fill: white; -fx-font-size: 12px;"/>
                    </StackPane>
                    <Label text="Choisir votre rôle"
                           style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 12px;"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            <Label text="Données protégées — RGPD"
                   style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.4);"/>
            <Label text="Déjà un compte ?" style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.7); -fx-padding: 16 0 0 0;"/>
            <Button text="Se connecter" onAction="#goToLogin"
                    style="-fx-background-color: transparent; -fx-text-fill: #F5C87A;
                           -fx-font-size: 13px; -fx-font-weight: 700; -fx-cursor: hand;
                           -fx-border-color: #F5C87A; -fx-border-radius: 8; -fx-border-width: 1;
                           -fx-padding: 6 20;"/>
        </VBox>

        <!-- ── DROITE : Formulaire ── -->
        <VBox prefHeight="620" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 0 22 22 0;">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox spacing="16" style="-fx-padding: 36 38;">

                    <Label text="Créer votre compte"
                           style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #2D3748;"/>

                    <!-- Nom + Prénom -->
                    <HBox spacing="16">
                        <VBox HBox.hgrow="ALWAYS" spacing="5">
                            <Label text="NOM" style="-fx-font-size: 10px; -fx-font-weight: 600; -fx-letter-spacing: 1; -fx-text-fill: #A0AEC0;"/>
                            <TextField fx:id="tfNom" promptText="Votre nom"
                                       style="-fx-background-color: #F7F5F2; -fx-border-color: #E8E4DF; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1.5; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="5">
                            <Label text="PRÉNOM" style="-fx-font-size: 10px; -fx-font-weight: 600; -fx-letter-spacing: 1; -fx-text-fill: #A0AEC0;"/>
                            <TextField fx:id="tfPrenom" promptText="Votre prénom"
                                       style="-fx-background-color: #F7F5F2; -fx-border-color: #E8E4DF; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1.5; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                        </VBox>
                    </HBox>

                    <!-- Email -->
                    <VBox spacing="5">
                        <Label text="ADRESSE EMAIL" style="-fx-font-size: 10px; -fx-font-weight: 600; -fx-letter-spacing: 1; -fx-text-fill: #A0AEC0;"/>
                        <TextField fx:id="tfEmail" promptText="vous@exemple.com"
                                   style="-fx-background-color: #F7F5F2; -fx-border-color: #E8E4DF; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1.5; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                    </VBox>

                    <!-- Téléphone -->
                    <VBox spacing="5">
                        <Label text="NUMÉRO DE TÉLÉPHONE" style="-fx-font-size: 10px; -fx-font-weight: 600; -fx-letter-spacing: 1; -fx-text-fill: #A0AEC0;"/>
                        <TextField fx:id="tfTel" promptText="Ex: 12345678"
                                   style="-fx-background-color: #F7F5F2; -fx-border-color: #E8E4DF; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1.5; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                    </VBox>

                    <!-- Mot de passe + Confirmer -->
                    <VBox spacing="8">
                        <HBox spacing="16">
                            <VBox HBox.hgrow="ALWAYS" spacing="5">
                                <Label text="MOT DE PASSE" style="-fx-font-size: 10px; -fx-font-weight: 600; -fx-letter-spacing: 1; -fx-text-fill: #A0AEC0;"/>
                                <PasswordField fx:id="pfMdp" promptText="Min. 8 car., 1 MAJ, 1 chiffre, 1 spécial"
                                               style="-fx-background-color: #F7F5F2; -fx-border-color: #E8E4DF; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1.5; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                            </VBox>
                            <VBox HBox.hgrow="ALWAYS" spacing="5">
                                <Label text="CONFIRMER" style="-fx-font-size: 10px; -fx-font-weight: 600; -fx-letter-spacing: 1; -fx-text-fill: #A0AEC0;"/>
                                <PasswordField fx:id="pfConfirm" promptText="Répéter le mot de passe"
                                               style="-fx-background-color: #F7F5F2; -fx-border-color: #E8E4DF; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1.5; -fx-padding: 10 14; -fx-font-size: 13px;"/>
                            </VBox>
                        </HBox>

                        <!-- Indicateur force + règles -->
                        <HBox spacing="20" alignment="CENTER_LEFT">
                            <Label fx:id="lblStrength" text="" visible="false"
                                   style="-fx-font-size:11px;-fx-text-fill:#A0AEC0;"/>
                            <Label text="✓ 8 car.  ✓ Maj  ✓ Chiffre  ✓ Spécial (!@#...)"
                                   style="-fx-font-size:10px;-fx-text-fill:#C0BAB2;-fx-font-style:italic;"/>
                        </HBox>
                    </VBox>

                    <!-- Rôle + Photo -->
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS" spacing="5">
                            <Label text="RÔLE" style="-fx-font-size: 10px; -fx-font-weight: 600; -fx-letter-spacing: 1; -fx-text-fill: #A0AEC0;"/>
                            <ComboBox fx:id="cbRole" maxWidth="Infinity"
                                      style="-fx-background-color: #F7F5F2; -fx-border-color: #E8E4DF; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1.5; -fx-padding: 4 10; -fx-font-size: 13px;"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="5">
                            <Label text="PHOTO (OPTIONNEL)" style="-fx-font-size: 10px; -fx-font-weight: 600; -fx-letter-spacing: 1; -fx-text-fill: #A0AEC0;"/>
                            <!-- Photo container avec preview -->
                            <StackPane fx:id="photoContainer" prefHeight="42" minHeight="42">
                                <Button text="📷 Choisir une photo" onAction="#handleChoosePhoto"
                                        maxWidth="Infinity" prefHeight="42"
                                        style="-fx-background-color: #FFF8F0; -fx-text-fill: #E8956D;
                                               -fx-border-color: #E8956D; -fx-border-width: 1.5;
                                               -fx-border-radius: 8; -fx-background-radius: 8;
                                               -fx-font-size: 12px; -fx-font-weight: 600; -fx-cursor: hand;"/>
                                <ImageView fx:id="imgSignUpPhoto" fitWidth="42" fitHeight="42"
                                           preserveRatio="true" visible="false">
                                    <clip><Circle radius="21" centerX="21" centerY="21"/></clip>
                                </ImageView>
                            </StackPane>
                            <Label fx:id="lblPhotoPlaceholder" text="Aucune photo sélectionnée"
                                   style="-fx-font-size: 10px; -fx-text-fill: #CBD5E0;"/>
                        </VBox>
                    </HBox>

                    <!-- Bouton inscription -->
                    <Button text="Créer mon compte" onAction="#handleSignUp"
                            maxWidth="Infinity" prefHeight="46"
                            style="-fx-background-color: #E8956D; -fx-text-fill: white;
                                   -fx-font-size: 14px; -fx-font-weight: 700;
                                   -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(232,149,109,0.4), 10, 0, 0, 4);"/>

                    <!-- Se connecter (bas) -->
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Déjà un compte ?" style="-fx-font-size: 12px; -fx-text-fill: #A0AEC0;"/>
                        <Button text="Se connecter" onAction="#goToLogin"
                                style="-fx-background-color: transparent; -fx-text-fill: #4A6FA5;
                                       -fx-font-size: 12px; -fx-font-weight: 700; -fx-cursor: hand;
                                       -fx-border-color: transparent; -fx-padding: 0;"/>
                    </HBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </HBox>
</StackPane>
