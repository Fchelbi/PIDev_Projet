<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="450.0"
            style="-fx-background-color: linear-gradient(to bottom, #667eea 0%, #764ba2 100%);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.SignUp">

    <VBox alignment="TOP_CENTER" spacing="20.0" AnchorPane.topAnchor="30.0"
          AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0">

        <!-- Titre -->
        <Label text="Inscription" textFill="WHITE">
            <font>
                <Font name="System Bold" size="32.0" />
            </font>
        </Label>

        <!-- Conteneur blanc pour le formulaire -->
        <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25;">

            <!-- Nom -->
            <VBox spacing="5.0">
                <Label text="Nom" style="-fx-text-fill: #333;">
                    <font><Font size="13.0" /></font>
                </Label>
                <TextField fx:id="tfNom" promptText="Votre nom"
                           style="-fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 8;">
                </TextField>
            </VBox>

            <!-- Prénom -->
            <VBox spacing="5.0">
                <Label text="Prénom" style="-fx-text-fill: #333;">
                    <font><Font size="13.0" /></font>
                </Label>
                <TextField fx:id="tfPrenom" promptText="Votre prénom"
                           style="-fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 8;">
                </TextField>
            </VBox>

            <!-- Email -->
            <VBox spacing="5.0">
                <Label text="Email" style="-fx-text-fill: #333;">
                    <font><Font size="13.0" /></font>
                </Label>
                <TextField fx:id="tfEmail" promptText="exemple@email.com"
                           style="-fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 8;">
                </TextField>
            </VBox>

            <!-- Téléphone -->
            <VBox spacing="5.0">
                <Label text="Numéro de téléphone" style="-fx-text-fill: #333;">
                    <font><Font size="13.0" /></font>
                </Label>
                <TextField fx:id="tfTel" promptText="12345678"
                           style="-fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 8;">
                </TextField>
            </VBox>

            <!-- Mot de passe -->
            <VBox spacing="5.0">
                <Label text="Mot de passe" style="-fx-text-fill: #333;">
                    <font><Font size="13.0" /></font>
                </Label>
                <PasswordField fx:id="pfMdp" promptText="••••••••"
                               style="-fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 8;">
                </PasswordField>
            </VBox>

            <!-- Rôle (ComboBox) -->
            <VBox spacing="5.0">
                <Label text="Rôle" style="-fx-text-fill: #333;">
                    <font><Font size="13.0" /></font>
                </Label>
                <ComboBox fx:id="cbRole" maxWidth="Infinity"
                          style="-fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5;">
                </ComboBox>
            </VBox>

            <!-- Bouton S'inscrire -->
            <Button text="Créer mon compte" onAction="#handleSignUp" maxWidth="Infinity"
                    style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 12; -fx-font-size: 14px; -fx-font-weight: bold;">
            </Button>

            <!-- Ligne de séparation -->
            <Separator prefWidth="200.0" />

            <!-- Lien vers Login -->
            <HBox alignment="CENTER" spacing="5.0">
                <Label text="Déjà un compte ?" style="-fx-text-fill: #666;" />
                <Button text="Se connecter" onAction="#switchToLogin"
                        style="-fx-background-color: transparent; -fx-text-fill: #667eea; -fx-underline: true; -fx-cursor: hand;">
                </Button>
            </HBox>

        </VBox>

    </VBox>

</AnchorPane>
