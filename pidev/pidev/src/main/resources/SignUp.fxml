<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.SignUp"
           prefHeight="750.0" prefWidth="1200.0"
           style="-fx-background-color: #F2D0BC;">

    <!-- Orbes fond -->
    <Circle radius="340" fill="#4A6FA5" opacity="0.11" translateX="-440" translateY="-160"/>
    <Circle radius="280" fill="#E8956D" opacity="0.10" translateX="430" translateY="200"/>
    <Circle radius="160" fill="#F5C87A" opacity="0.15" translateX="100" translateY="-280"/>

    <HBox alignment="CENTER" spacing="0" maxWidth="960" maxHeight="600">

        <!-- ── GAUCHE : Branding ── -->
        <VBox prefWidth="360" prefHeight="600" alignment="CENTER" spacing="0"
              style="-fx-background-color: #4A6FA5;
                     -fx-background-radius: 22 0 0 22;
                     -fx-padding: 50 42;">

            <!-- Logo -->
            <StackPane alignment="CENTER" style="-fx-padding: 0 0 22 0;">
                <Circle radius="44" fill="#7B9ED9" opacity="0.3"/>
                <Ellipse radiusX="22" radiusY="28" fill="#3D5A8A" translateX="-16" translateY="-2"/>
                <Ellipse radiusX="22" radiusY="28" fill="#F5C87A" translateX="16" translateY="-2"/>
                <StackPane translateX="-18" translateY="-24">
                    <Ellipse radiusX="15" radiusY="10" fill="#FDFAF6"/>
                    <HBox spacing="3" alignment="CENTER">
                        <Circle radius="2" fill="#4A6FA5"/>
                        <Circle radius="2" fill="#4A6FA5"/>
                        <Circle radius="2" fill="#4A6FA5"/>
                    </HBox>
                </StackPane>
                <StackPane translateX="18" translateY="-24">
                    <Ellipse radiusX="15" radiusY="10" fill="#FDFAF6"/>
                    <HBox spacing="3" alignment="CENTER">
                        <Circle radius="2" fill="#C06A3A"/>
                        <Circle radius="2" fill="#C06A3A"/>
                        <Circle radius="2" fill="#C06A3A"/>
                    </HBox>
                </StackPane>
            </StackPane>

            <HBox alignment="CENTER" spacing="0">
                <Label text="Echo" textFill="WHITE"
                       style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-font-family: 'Georgia';"/>
                <Label text="Care" textFill="#F5C87A"
                       style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-font-family: 'Georgia';"/>
            </HBox>
            <Label text="Rejoignez notre plateforme"
                   textFill="#BDD0EE"
                   style="-fx-font-size: 12px; -fx-padding: 5 0 22 0;"/>

            <!-- Etapes -->
            <VBox spacing="0"
                  style="-fx-background-color: rgba(255,255,255,0.12);
                         -fx-background-radius: 14; -fx-padding: 20 22;">
                <Label text="INSCRIPTION EN 3 ÉTAPES"
                       textFill="#BDD0EE"
                       style="-fx-font-size: 10px; -fx-padding: 0 0 14 0;"/>

                <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0 0 12 0;">
                    <StackPane prefWidth="28" prefHeight="28">
                        <Circle radius="14" fill="WHITE"/>
                        <Label text="1" textFill="#4A6FA5"
                               style="-fx-font-size: 12px; -fx-font-weight: 700;"/>
                    </StackPane>
                    <Label text="Informations personnelles"
                           textFill="WHITE"
                           style="-fx-font-size: 13px; -fx-font-weight: 600;"/>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0 0 12 0;">
                    <StackPane prefWidth="28" prefHeight="28">
                        <Circle radius="14" fill="#7B9ED9"/>
                        <Label text="2" textFill="WHITE" style="-fx-font-size: 12px;"/>
                    </StackPane>
                    <Label text="Identifiants de connexion"
                           textFill="#BDD0EE"
                           style="-fx-font-size: 13px;"/>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane prefWidth="28" prefHeight="28">
                        <Circle radius="14" fill="#7B9ED9"/>
                        <Label text="3" textFill="WHITE" style="-fx-font-size: 12px;"/>
                    </StackPane>
                    <Label text="Choisir votre rôle"
                           textFill="#BDD0EE"
                           style="-fx-font-size: 13px;"/>
                </HBox>
            </VBox>

            <Label text="Données protégées — RGPD"
                   textFill="#BDD0EE"
                   style="-fx-font-size: 11px; -fx-padding: 18 0 0 0;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="0">
                <Label text="Déjà un compte ?  " textFill="#BDD0EE" style="-fx-font-size: 12px;"/>
                <Hyperlink text="Se connecter" onAction="#switchToLogin"
                           style="-fx-text-fill: #F5C87A; -fx-font-weight: 700;
                                  -fx-font-size: 12px; -fx-border-color: transparent;"/>
            </HBox>

        </VBox>

        <!-- ── DROITE : Formulaire ── -->
        <ScrollPane fitToWidth="true" prefWidth="600" prefHeight="600"
                    style="-fx-background: #FDFAF6; -fx-background-color: #FDFAF6; -fx-border-color: transparent;">
            <VBox style="-fx-background-color: #FDFAF6;
                         -fx-background-radius: 0 22 22 0;
                         -fx-padding: 44 52;" spacing="0">

                <!-- Accent trait -->
                <HBox spacing="4" style="-fx-padding: 0 0 26 0;">
                    <Rectangle width="36" height="4" arcWidth="4" arcHeight="4" fill="#4A6FA5"/>
                    <Rectangle width="20" height="4" arcWidth="4" arcHeight="4" fill="#E8956D"/>
                    <Rectangle width="10" height="4" arcWidth="4" arcHeight="4" fill="#F5C87A"/>
                </HBox>

                <Label text="Créer un compte"
                       style="-fx-font-size: 28px; -fx-font-weight: 700;
                              -fx-font-family: 'Georgia'; -fx-text-fill: #3D5A8A;"/>
                <Label text="Remplissez le formulaire pour commencer"
                       style="-fx-font-size: 13px; -fx-text-fill: #A0B8D8; -fx-padding: 4 0 24 0;"/>

                <!-- Nom + Prénom -->
                <HBox spacing="16">
                    <VBox HBox.hgrow="ALWAYS" spacing="0">
                        <Label text="NOM"
                               style="-fx-font-size: 10px; -fx-text-fill: #7B9ED9;
                                      -fx-font-weight: 700; -fx-padding: 0 0 7 2;"/>
                        <TextField fx:id="tfNom" promptText="Votre nom"
                                   style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                          -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;
                                          -fx-padding: 12 16; -fx-font-size: 14px;
                                          -fx-text-fill: #3D5A8A; -fx-prompt-text-fill: #C0D3EB;"/>
                        <Label fx:id="errNom" text=""
                               style="-fx-text-fill: #D94F4F; -fx-font-size: 11px; -fx-padding: 4 0 0 2;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="0">
                        <Label text="PRÉNOM"
                               style="-fx-font-size: 10px; -fx-text-fill: #7B9ED9;
                                      -fx-font-weight: 700; -fx-padding: 0 0 7 2;"/>
                        <TextField fx:id="tfPrenom" promptText="Votre prénom"
                                   style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                          -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;
                                          -fx-padding: 12 16; -fx-font-size: 14px;
                                          -fx-text-fill: #3D5A8A; -fx-prompt-text-fill: #C0D3EB;"/>
                        <Label fx:id="errPrenom" text=""
                               style="-fx-text-fill: #D94F4F; -fx-font-size: 11px; -fx-padding: 4 0 0 2;"/>
                    </VBox>
                </HBox>

                <!-- Email -->
                <VBox spacing="0" style="-fx-padding: 13 0 0 0;">
                    <Label text="ADRESSE EMAIL"
                           style="-fx-font-size: 10px; -fx-text-fill: #7B9ED9;
                                  -fx-font-weight: 700; -fx-padding: 0 0 7 2;"/>
                    <TextField fx:id="tfEmail" promptText="vous@exemple.com"
                               style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                      -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;
                                      -fx-padding: 12 16; -fx-font-size: 14px;
                                      -fx-text-fill: #3D5A8A; -fx-prompt-text-fill: #C0D3EB;"/>
                    <Label fx:id="errEmail" text=""
                           style="-fx-text-fill: #D94F4F; -fx-font-size: 11px; -fx-padding: 4 0 0 2;"/>
                </VBox>

                <!-- Téléphone -->
                <VBox spacing="0" style="-fx-padding: 13 0 0 0;">
                    <Label text="NUMÉRO DE TÉLÉPHONE"
                           style="-fx-font-size: 10px; -fx-text-fill: #7B9ED9;
                                  -fx-font-weight: 700; -fx-padding: 0 0 7 2;"/>
                    <TextField fx:id="tfTel" promptText="Ex: 12345678"
                               style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                      -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;
                                      -fx-padding: 12 16; -fx-font-size: 14px;
                                      -fx-text-fill: #3D5A8A; -fx-prompt-text-fill: #C0D3EB;"/>
                    <Label fx:id="errTel" text=""
                           style="-fx-text-fill: #D94F4F; -fx-font-size: 11px; -fx-padding: 4 0 0 2;"/>
                </VBox>

                <!-- MDP + Confirmer -->
                <HBox spacing="16" style="-fx-padding: 13 0 0 0;">
                    <VBox HBox.hgrow="ALWAYS" spacing="0">
                        <Label text="MOT DE PASSE"
                               style="-fx-font-size: 10px; -fx-text-fill: #7B9ED9;
                                      -fx-font-weight: 700; -fx-padding: 0 0 7 2;"/>
                        <PasswordField fx:id="pfMdp" promptText="Ex: MonMdp@2025"
                                       style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                              -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;
                                              -fx-padding: 12 16; -fx-font-size: 14px; -fx-prompt-text-fill: #C0D3EB;"/>
                        <Label fx:id="errMdp" text=""
                               style="-fx-text-fill: #D94F4F; -fx-font-size: 11px; -fx-padding: 4 0 0 2;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="0">
                        <Label text="CONFIRMER"
                               style="-fx-font-size: 10px; -fx-text-fill: #7B9ED9;
                                      -fx-font-weight: 700; -fx-padding: 0 0 7 2;"/>
                        <PasswordField fx:id="pfConfirm" promptText="Répéter"
                                       style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                              -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;
                                              -fx-padding: 12 16; -fx-font-size: 14px; -fx-prompt-text-fill: #C0D3EB;"/>
                        <Label fx:id="errConfirm" text=""
                               style="-fx-text-fill: #D94F4F; -fx-font-size: 11px; -fx-padding: 4 0 0 2;"/>
                    </VBox>
                </HBox>

                <!-- Rôle + Photo -->
                <HBox spacing="16" style="-fx-padding: 13 0 0 0;">
                    <VBox HBox.hgrow="ALWAYS" spacing="0">
                        <Label text="RÔLE"
                               style="-fx-font-size: 10px; -fx-text-fill: #7B9ED9;
                                      -fx-font-weight: 700; -fx-padding: 0 0 7 2;"/>
                        <ComboBox fx:id="cbRole" maxWidth="Infinity" promptText="Choisir un rôle"
                                  style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                         -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;
                                         -fx-padding: 7 14; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="0">
                        <Label text="PHOTO (OPTIONNEL)"
                               style="-fx-font-size: 10px; -fx-text-fill: #7B9ED9;
                                      -fx-font-weight: 700; -fx-padding: 0 0 7 2;"/>
                        <Button fx:id="btnPhoto" text="Choisir une photo"
                                onAction="#handleChoosePhoto" maxWidth="Infinity"
                                style="-fx-background-color: #F6F3F0; -fx-text-fill: #E8956D;
                                       -fx-border-color: #F0CBA8; -fx-border-width: 2;
                                       -fx-border-radius: 10; -fx-background-radius: 10;
                                       -fx-padding: 12; -fx-font-size: 13px;
                                       -fx-font-weight: 600; -fx-cursor: hand;"/>
                        <Label fx:id="lblPhotoPath" text="Aucune photo sélectionnée"
                               style="-fx-font-size: 11px; -fx-text-fill: #C8BEB5; -fx-padding: 5 0 0 2;"/>
                    </VBox>
                </HBox>

                <!-- Bouton -->
                <Button text="Créer mon compte"
                        onAction="#handleSignUp" maxWidth="Infinity"
                        style="-fx-background-color: #E8956D; -fx-text-fill: white;
                               -fx-font-size: 15px; -fx-font-weight: 700;
                               -fx-padding: 14; -fx-background-radius: 10;
                               -fx-cursor: hand; -fx-border-color: transparent;">
                    <VBox.margin><javafx.geometry.Insets top="22"/></VBox.margin>
                </Button>

                <HBox alignment="CENTER" spacing="0" style="-fx-padding: 12 0 0 0;">
                    <Label text="Déjà un compte ?  "
                           style="-fx-text-fill: #A0B8D8; -fx-font-size: 13px;"/>
                    <Hyperlink text="Se connecter" onAction="#switchToLogin"
                               style="-fx-text-fill: #3D5A8A; -fx-font-weight: 700;
                                      -fx-font-size: 13px; -fx-border-color: transparent;"/>
                </HBox>

            </VBox>
        </ScrollPane>

    </HBox>

</StackPane>
