<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="400.0"
            style="-fx-background-color: linear-gradient(to bottom, #667eea 0%, #764ba2 100%);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.SignIn">

    <VBox alignment="CENTER" spacing="20.0" AnchorPane.topAnchor="50.0"
          AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0">

        <!-- Titre -->
        <Label text="Connexion" textFill="WHITE">
            <font>
                <Font name="System Bold" size="32.0" />
            </font>
        </Label>

        <!-- Conteneur blanc pour le formulaire -->
        <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 30;">

            <!-- Email Field -->
            <VBox spacing="5.0">
                <Label text="Email" style="-fx-text-fill: #333;">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <TextField fx:id="tfEmail" promptText="exemple@email.com"
                           style="-fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 10;">
                </TextField>
            </VBox>

            <!-- Password Field -->
            <VBox spacing="5.0">
                <Label text="Mot de passe" style="-fx-text-fill: #333;">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <PasswordField fx:id="pfMdp" promptText="••••••••"
                               style="-fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 10;">
                </PasswordField>
            </VBox>

            <!-- Bouton Login -->
            <Button text="Se connecter" onAction="#handleLogin" maxWidth="Infinity"
                    style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 12; -fx-font-size: 14px; -fx-font-weight: bold;">
            </Button>

            <!-- Ligne de séparation -->
            <Separator prefWidth="200.0" />

            <!-- Lien vers Sign Up -->
            <HBox alignment="CENTER" spacing="5.0">
                <Label text="Pas encore de compte ?" style="-fx-text-fill: #666;" />
                <Button text="S'inscrire" onAction="#switchToSignUp"
                        style="-fx-background-color: transparent; -fx-text-fill: #667eea; -fx-underline: true; -fx-cursor: hand;">
                </Button>
            </HBox>

        </VBox>

    </VBox>

</AnchorPane>
