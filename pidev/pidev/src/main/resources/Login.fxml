<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.SignIn"
           prefHeight="700.0" prefWidth="1200.0"
           style="-fx-background-color: #F8F9FC;">

    <HBox alignment="CENTER" spacing="0">

        <!-- Left Panel -->
        <VBox alignment="CENTER" spacing="30" prefWidth="500"
              style="-fx-background-color: linear-gradient(to bottom right, #C3CEF0, #EABDD4);
                     -fx-padding: 60;">

            <StackPane>
                <Circle radius="70" fill="WHITE" opacity="0.4"/>
                <Circle radius="60" fill="WHITE" opacity="0.45"/>
                <SVGPath content="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"
                         fill="#4A5568" scaleX="3" scaleY="3"/>
            </StackPane>

            <VBox alignment="CENTER" spacing="12">
                <Label text="Bienvenue" textFill="#4A5568"
                       style="-fx-font-size: 42px; -fx-font-weight: 300;">
                    <font><Font name="System Light" size="42"/></font>
                </Label>
                <Label text="Gérez votre plateforme en toute simplicité"
                       textFill="#5A6578"
                       style="-fx-font-size: 16px; -fx-opacity: 0.9;"
                       wrapText="true" textAlignment="CENTER" maxWidth="350"/>
            </VBox>

            <VBox spacing="20" alignment="CENTER_LEFT"
                  style="-fx-padding: 40 0 0 0;">
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Circle radius="4" fill="#4A5568" opacity="0.6"/>
                    <Label text="Gestion complète des utilisateurs"
                           textFill="#4A5568" style="-fx-font-size: 14px; -fx-opacity: 0.85;"/>
                </HBox>
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Circle radius="4" fill="#4A5568" opacity="0.6"/>
                    <Label text="Statistiques en temps réel"
                           textFill="#4A5568" style="-fx-font-size: 14px; -fx-opacity: 0.85;"/>
                </HBox>
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Circle radius="4" fill="#4A5568" opacity="0.6"/>
                    <Label text="Interface moderne et intuitive"
                           textFill="#4A5568" style="-fx-font-size: 14px; -fx-opacity: 0.85;"/>
                </HBox>
            </VBox>

        </VBox>

        <!-- Right Panel -->
        <VBox alignment="CENTER" spacing="0" HBox.hgrow="ALWAYS"
              style="-fx-padding: 60;">

            <VBox alignment="CENTER_LEFT" spacing="35" maxWidth="400">

                <VBox spacing="8">
                    <Label text="Connexion"
                           style="-fx-font-size: 36px; -fx-font-weight: 600; -fx-text-fill: #4A5568;">
                        <font><Font name="System Bold" size="36"/></font>
                    </Label>
                    <Label text="Entrez vos identifiants pour accéder"
                           style="-fx-font-size: 14px; -fx-text-fill: #A0AEC0;"/>
                </VBox>

                <!-- Email -->
                <VBox spacing="10">
                    <Label text="Adresse email"
                           style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: 500;"/>
                    <HBox spacing="0" alignment="CENTER_LEFT"
                          style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0;
                                 -fx-border-radius: 8; -fx-background-radius: 8;
                                 -fx-border-width: 1.5; -fx-padding: 4;">
                        <StackPane prefWidth="45" alignment="CENTER">
                            <SVGPath content="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                                     fill="#A0AEC0" scaleX="0.9" scaleY="0.9"/>
                        </StackPane>
                        <TextField fx:id="tfEmail"
                                   promptText="vous@exemple.com"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent;
                                          -fx-padding: 12 15; -fx-font-size: 14px; -fx-prompt-text-fill: #CBD5E0;"/>
                    </HBox>
                </VBox>

                <!-- Password -->
                <VBox spacing="10">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Mot de passe"
                               style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: 500;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <!-- ✅ FIX: onAction ajouté au lien "Mot de passe oublié" -->
                        <Hyperlink text="Mot de passe oublié ?" onAction="#handleForgotPassword"
                                   style="-fx-text-fill: #D4A5BD; -fx-font-size: 12px;"/>
                    </HBox>
                    <HBox spacing="0" alignment="CENTER_LEFT"
                          style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0;
                                 -fx-border-radius: 8; -fx-background-radius: 8;
                                 -fx-border-width: 1.5; -fx-padding: 4;">
                        <StackPane prefWidth="45" alignment="CENTER">
                            <SVGPath content="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                                     fill="#A0AEC0" scaleX="0.9" scaleY="0.9"/>
                        </StackPane>
                        <PasswordField fx:id="pfMdp"
                                       promptText="••••••••"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: transparent; -fx-border-color: transparent;
                                              -fx-padding: 12 15; -fx-font-size: 14px; -fx-prompt-text-fill: #CBD5E0;"/>
                    </HBox>
                </VBox>

                <!-- Button -->
                <Button text="Se connecter" onAction="#handleLogin"
                        maxWidth="Infinity"
                        style="-fx-background-color: linear-gradient(to right, #A7B5E0, #D4A5BD);
                               -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600;
                               -fx-padding: 16; -fx-background-radius: 8; -fx-cursor: hand;">
                    <font><Font name="System Bold" size="15"/></font>
                </Button>

                <!-- Divider -->
                <HBox alignment="CENTER" spacing="15">
                    <Line endX="80" stroke="#E2E8F0" strokeWidth="1"/>
                    <Label text="ou" style="-fx-text-fill: #CBD5E0; -fx-font-size: 13px;"/>
                    <Line endX="80" stroke="#E2E8F0" strokeWidth="1"/>
                </HBox>

                <!-- Sign Up -->
                <HBox alignment="CENTER" spacing="6">
                    <Label text="Pas encore de compte ?"
                           style="-fx-text-fill: #A0AEC0; -fx-font-size: 14px;"/>
                    <Hyperlink text="Créer un compte" onAction="#switchToSignUp"
                               style="-fx-text-fill: #9FAEE0; -fx-font-weight: 600; -fx-font-size: 14px;"/>
                </HBox>

            </VBox>
        </VBox>

    </HBox>

</StackPane>
