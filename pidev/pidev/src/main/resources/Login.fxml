<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<!--
  PALETTE IMAGE :
  #4A6FA5  Bleu profond   — sidebar, textes titres
  #7B9ED9  Bleu doux      — accents, bordures
  #E8956D  Pêche coral    — bouton principal, highlights
  #F5C87A  Ambre doré     — accents chauds
  #F2D0BC  Pêche pâle     — fond général
  #3D5A8A  Bleu foncé     — textes sombres
  #FDFAF6  Blanc chaud    — cards
-->

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.SignIn"
           prefHeight="700.0" prefWidth="1200.0"
           style="-fx-background-color: #F2D0BC;">

    <!-- Orbes décoratifs fond -->
    <Circle radius="380" fill="#E8956D" opacity="0.13" translateX="-420" translateY="-150"/>
    <Circle radius="300" fill="#7B9ED9" opacity="0.13" translateX="440" translateY="160"/>
    <Circle radius="200" fill="#F5C87A" opacity="0.18" translateX="180" translateY="-260"/>
    <Circle radius="150" fill="#4A6FA5" opacity="0.08" translateX="-200" translateY="260"/>

    <!-- Carte centrale flottante -->
    <HBox alignment="CENTER" spacing="0" maxWidth="860" maxHeight="520">

        <!-- ── PANNEAU GAUCHE : Branding ── -->
        <VBox prefWidth="350" prefHeight="520" alignment="CENTER" spacing="0"
              style="-fx-background-color: #4A6FA5;
                     -fx-background-radius: 22 0 0 22;
                     -fx-padding: 52 44;">

            <!-- Logo : 2 silhouettes face à face -->
            <StackPane alignment="CENTER" style="-fx-padding: 0 0 24 0;">
                <!-- Halo fond -->
                <Circle radius="46" fill="#7B9ED9" opacity="0.3"/>
                <!-- Tête gauche bleu -->
                <Ellipse radiusX="22" radiusY="28" fill="#3D5A8A" translateX="-16" translateY="-2"/>
                <!-- Tête droite ambre -->
                <Ellipse radiusX="22" radiusY="28" fill="#F5C87A" translateX="16" translateY="-2"/>
                <!-- Bulle gauche -->
                <StackPane translateX="-18" translateY="-24">
                    <Ellipse radiusX="15" radiusY="10" fill="#FDFAF6"/>
                    <HBox spacing="3" alignment="CENTER">
                        <Circle radius="2" fill="#4A6FA5"/>
                        <Circle radius="2" fill="#4A6FA5"/>
                        <Circle radius="2" fill="#4A6FA5"/>
                    </HBox>
                </StackPane>
                <!-- Bulle droite -->
                <StackPane translateX="18" translateY="-24">
                    <Ellipse radiusX="15" radiusY="10" fill="#FDFAF6"/>
                    <HBox spacing="3" alignment="CENTER">
                        <Circle radius="2" fill="#C06A3A"/>
                        <Circle radius="2" fill="#C06A3A"/>
                        <Circle radius="2" fill="#C06A3A"/>
                    </HBox>
                </StackPane>
            </StackPane>

            <!-- Nom app -->
            <HBox alignment="CENTER" spacing="0">
                <Label text="Echo" textFill="WHITE"
                       style="-fx-font-size: 38px; -fx-font-weight: 700; -fx-font-family: 'Georgia';"/>
                <Label text="Care" textFill="#F5C87A"
                       style="-fx-font-size: 38px; -fx-font-weight: 700; -fx-font-family: 'Georgia';"/>
            </HBox>
            <Label text="Psychologie · Bien-être"
                   textFill="#BDD0EE"
                   style="-fx-font-size: 12px; -fx-font-style: italic; -fx-padding: 4 0 0 0;"/>

            <!-- Séparateur -->
            <HBox alignment="CENTER" spacing="8" style="-fx-padding: 24 0 22 0;">
                <Rectangle width="40" height="1" fill="WHITE" opacity="0.3"/>
                <Circle radius="3" fill="#F5C87A" opacity="0.7"/>
                <Rectangle width="40" height="1" fill="WHITE" opacity="0.3"/>
            </HBox>

            <!-- 3 points clés -->
            <VBox spacing="14">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Rectangle width="3" height="28" arcWidth="3" arcHeight="3" fill="#E8956D"/>
                    <VBox spacing="1">
                        <Label text="Suivi personnalisé"
                               textFill="WHITE"
                               style="-fx-font-size: 12px; -fx-font-weight: 600;"/>
                        <Label text="Rapports automatisés"
                               textFill="#BDD0EE"
                               style="-fx-font-size: 11px;"/>
                    </VBox>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Rectangle width="3" height="28" arcWidth="3" arcHeight="3" fill="#F5C87A"/>
                    <VBox spacing="1">
                        <Label text="Communication facilitée"
                               textFill="WHITE"
                               style="-fx-font-size: 12px; -fx-font-weight: 600;"/>
                        <Label text="Coach · Patient · Admin"
                               textFill="#BDD0EE"
                               style="-fx-font-size: 11px;"/>
                    </VBox>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Rectangle width="3" height="28" arcWidth="3" arcHeight="3" fill="#7B9ED9"/>
                    <VBox spacing="1">
                        <Label text="Sécurité renforcée"
                               textFill="WHITE"
                               style="-fx-font-size: 12px; -fx-font-weight: 600;"/>
                        <Label text="Double authentification"
                               textFill="#BDD0EE"
                               style="-fx-font-size: 11px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Bas -->
            <Region VBox.vgrow="ALWAYS"/>
            <Label text="EchoCare v2.0"
                   textFill="#7B9ED9"
                   style="-fx-font-size: 10px;"/>

        </VBox>

        <!-- ── PANNEAU DROIT : Formulaire ── -->
        <VBox prefWidth="380" prefHeight="520" alignment="CENTER" spacing="0"
              style="-fx-background-color: #FDFAF6;
                     -fx-background-radius: 0 22 22 0;
                     -fx-padding: 48 44;">

            <!-- Accent trait coloré en haut -->
            <HBox spacing="0" style="-fx-padding: 0 0 28 0;">
                <Rectangle width="36" height="4" arcWidth="4" arcHeight="4" fill="#E8956D"/>
                <Rectangle width="18" height="4" arcWidth="4" arcHeight="4" fill="#F5C87A">
                    <HBox.margin><javafx.geometry.Insets left="4"/></HBox.margin>
                </Rectangle>
                <Rectangle width="8" height="4" arcWidth="4" arcHeight="4" fill="#7B9ED9">
                    <HBox.margin><javafx.geometry.Insets left="4"/></HBox.margin>
                </Rectangle>
            </HBox>

            <Label text="Bon retour"
                   style="-fx-font-size: 28px; -fx-font-weight: 700;
                          -fx-font-family: 'Georgia'; -fx-text-fill: #3D5A8A;"/>
            <Label text="Connectez-vous à votre espace"
                   style="-fx-font-size: 13px; -fx-text-fill: #A0B8D8; -fx-padding: 4 0 28 0;"/>

            <!-- Champ Email -->
            <Label text="ADRESSE EMAIL"
                   style="-fx-font-size: 10px; -fx-text-fill: #7B9ED9;
                          -fx-font-weight: 700; -fx-padding: 0 0 7 2;"/>
            <TextField fx:id="tfEmail" promptText="vous@exemple.com"
                       style="-fx-background-color: #F6F3F0;
                              -fx-border-color: #D5E3F5; -fx-border-width: 2;
                              -fx-border-radius: 10; -fx-background-radius: 10;
                              -fx-padding: 13 16; -fx-font-size: 14px;
                              -fx-text-fill: #3D5A8A; -fx-prompt-text-fill: #C0D3EB;"/>

            <!-- Champ MDP -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 18 0 7 0;">
                <Label text="MOT DE PASSE"
                       style="-fx-font-size: 10px; -fx-text-fill: #7B9ED9;
                              -fx-font-weight: 700; -fx-padding: 0 0 0 2;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Hyperlink text="Oublié ?" onAction="#handleForgotPassword"
                           style="-fx-text-fill: #E8956D; -fx-font-size: 12px;
                                  -fx-border-color: transparent; -fx-underline: false;"/>
            </HBox>
            <PasswordField fx:id="pfMdp" promptText="••••••••"
                           style="-fx-background-color: #F6F3F0;
                                  -fx-border-color: #D5E3F5; -fx-border-width: 2;
                                  -fx-border-radius: 10; -fx-background-radius: 10;
                                  -fx-padding: 13 16; -fx-font-size: 14px;
                                  -fx-text-fill: #3D5A8A; -fx-prompt-text-fill: #C0D3EB;"/>

            <!-- Bouton connexion -->
            <Button text="Se connecter"
                    onAction="#handleLogin" maxWidth="Infinity"
                    style="-fx-background-color: #E8956D; -fx-text-fill: white;
                           -fx-font-size: 15px; -fx-font-weight: 700;
                           -fx-padding: 14; -fx-background-radius: 10;
                           -fx-cursor: hand; -fx-border-color: transparent;">
                <VBox.margin><javafx.geometry.Insets top="22"/></VBox.margin>
            </Button>

            <!-- Séparateur -->
            <HBox alignment="CENTER" spacing="12" style="-fx-padding: 18 0 14 0;">
                <Rectangle width="100" height="1" fill="#EDE8E3"/>
                <Label text="ou" style="-fx-text-fill: #CCC5BC; -fx-font-size: 12px;"/>
                <Rectangle width="100" height="1" fill="#EDE8E3"/>
            </HBox>

            <!-- Bouton inscription -->
            <Button text="Créer un compte"
                    onAction="#switchToSignUp" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #4A6FA5;
                           -fx-font-size: 13px; -fx-font-weight: 600;
                           -fx-padding: 12; -fx-background-radius: 10;
                           -fx-cursor: hand; -fx-border-color: #C0D3EB;
                           -fx-border-width: 2; -fx-border-radius: 10;"/>

            <!-- Note sécurité -->
            <HBox alignment="CENTER" spacing="6" style="-fx-padding: 16 0 0 0;">
                <Circle radius="4" fill="#F5C87A"/>
                <Label text="SSL · Données protégées · RGPD"
                       style="-fx-font-size: 11px; -fx-text-fill: #C8BEB5;"/>
            </HBox>

        </VBox>
    </HBox>

</StackPane>
