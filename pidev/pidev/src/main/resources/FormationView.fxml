<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.web.WebView?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.FormationController"
      spacing="15">
    <padding><Insets top="10" bottom="10" left="10" right="10"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="📚 Gestion des Formations"
               style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <TextField fx:id="tfSearch" promptText="🔍 Rechercher..."
                   prefWidth="250" onKeyReleased="#handleSearch"
                   styleClass="search-field"/>
        <Button text="➕ Ajouter" onAction="#showAddForm"
                styleClass="btn-add-new"/>
    </HBox>

    <Separator/>

    <StackPane fx:id="formationContent" VBox.vgrow="ALWAYS">

        <!-- ═══ TABLE SECTION ═══ -->
        <VBox fx:id="tableSection" spacing="10">
            <TableView fx:id="tvFormations" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colTitle" text="Titre" prefWidth="150"/>
                    <TableColumn fx:id="colDescription" text="Description" prefWidth="200"/>
                    <TableColumn fx:id="colCategory" text="Catégorie" prefWidth="120"/>
                    <TableColumn fx:id="colVideo" text="Vidéo" prefWidth="80"/>
                    <TableColumn fx:id="colQuiz" text="Quiz" prefWidth="100"/>
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="160"/>
                </columns>
                <placeholder>
                    <Label text="Aucune formation trouvée"/>
                </placeholder>
            </TableView>

            <HBox alignment="CENTER_LEFT">
                <Label fx:id="lblTotal" text="Total: 0"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="🔄 Rafraîchir" onAction="#handleRefresh"
                        styleClass="btn-refresh"/>
            </HBox>
        </VBox>

        <!-- ═══ ADD/EDIT FORM SECTION ═══ -->
        <VBox fx:id="formSection" spacing="15" visible="false" managed="false">
            <Label fx:id="lblFormTitle" text="➕ Ajouter Formation"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <VBox spacing="15" styleClass="form-card" maxWidth="600">
                <padding><Insets top="25" bottom="25" left="25" right="25"/></padding>

                <Label text="Titre:" styleClass="form-label"/>
                <TextField fx:id="tfTitle" promptText="Entrer le titre"
                           styleClass="form-input"/>

                <Label text="Description:" styleClass="form-label"/>
                <TextArea fx:id="taDescription" promptText="Entrer la description"
                          prefRowCount="3" wrapText="true" styleClass="form-input"/>

                <Label text="Vidéo (URL YouTube ou fichier):" styleClass="form-label"/>
                <HBox spacing="10">
                    <TextField fx:id="tfVideoUrl" promptText="Ex: https://youtube.com/watch?v=..."
                               styleClass="form-input" HBox.hgrow="ALWAYS"/>
                    <Button text="📁" onAction="#handleChooseVideo"
                            style="-fx-background-color: #636e72; -fx-text-fill: white;
                                   -fx-cursor: hand; -fx-font-size: 14px;"/>
                </HBox>

                <Label text="Catégorie:" styleClass="form-label"/>
                <ComboBox fx:id="cbCategory" promptText="Choisir catégorie"
                          prefWidth="300" styleClass="form-input"/>

                <Label fx:id="lblError" text="" style="-fx-text-fill: red;"/>

                <HBox spacing="15">
                    <padding><Insets top="10"/></padding>
                    <Button fx:id="btnSave" text="✅ Enregistrer"
                            onAction="#handleSave" styleClass="btn-save"/>
                    <Button text="🔄 Effacer" onAction="#handleClear"
                            styleClass="btn-clear"/>
                    <Button text="↩️ Retour" onAction="#showTable"
                            styleClass="btn-back"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- ═══ VIDEO PLAYER SECTION ═══ -->
        <VBox fx:id="videoSection" spacing="15" visible="false" managed="false">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Button text="↩️ Retour" onAction="#showTable" styleClass="btn-back"/>
                <Label fx:id="lblVideoTitle" text=""
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>

            <WebView fx:id="webVideoPlayer" prefHeight="400"/>

            <Label fx:id="lblVideoDescription" text="" wrapText="true"
                   style="-fx-font-size: 14px; -fx-text-fill: #636e72;"/>
        </VBox>

        <!-- ═══ QUIZ SECTION ═══ -->
        <VBox fx:id="quizSection" spacing="15" visible="false" managed="false">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Button text="↩️ Retour" onAction="#showTable" styleClass="btn-back"/>
                <Label fx:id="lblQuizTitle" text=""
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>

            <VBox fx:id="quizFormArea" spacing="15" styleClass="form-card" maxWidth="600">
                <padding><Insets top="25" bottom="25" left="25" right="25"/></padding>

                <Label text="Titre du Quiz:" styleClass="form-label"/>
                <TextField fx:id="tfQuizTitle" promptText="Entrer le titre du quiz"
                           styleClass="form-input"/>

                <Label text="Score minimum (%):" styleClass="form-label"/>
                <TextField fx:id="tfPassingScore" promptText="70"
                           styleClass="form-input"/>

                <Label fx:id="lblQuizError" text="" style="-fx-text-fill: red;"/>

                <HBox spacing="15">
                    <Button fx:id="btnSaveQuiz" text="✅ Enregistrer Quiz"
                            onAction="#handleSaveQuiz" styleClass="btn-save"/>
                    <Button text="↩️ Retour" onAction="#showTable"
                            styleClass="btn-back"/>
                </HBox>
            </VBox>

            <!-- Questions List -->
            <VBox fx:id="questionsArea" spacing="10">
                <Label text="📋 Questions:" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <VBox fx:id="questionsList" spacing="10"/>
                <Button text="➕ Ajouter Question" onAction="#handleAddQuestion"
                        styleClass="btn-add-new"/>
            </VBox>
        </VBox>

    </StackPane>

</VBox>