<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.FormationController"
      spacing="15">
    <padding><Insets top="10" bottom="10" left="10" right="10"/></padding>

    <!-- Header + Add Button -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="📚 Gestion des Formations"
               style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <TextField fx:id="tfSearch" promptText="🔍 Rechercher..."
                   prefWidth="250" onKeyReleased="#handleSearch"
                   styleClass="search-field"/>
        <Button text="➕ Ajouter" onAction="#showAddForm"
                styleClass="btn-add-new"/>
    </HBox>

    <Separator/>

    <!-- Content: Table OR Form (switched dynamically) -->
    <StackPane fx:id="formationContent" VBox.vgrow="ALWAYS">

        <!-- TABLE VIEW (shown by default) -->
        <VBox fx:id="tableSection" spacing="10">
            <TableView fx:id="tvFormations" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colTitle" text="Title" prefWidth="180"/>
                    <TableColumn fx:id="colDescription" text="Description" prefWidth="250"/>
                    <TableColumn fx:id="colVideoUrl" text="Video URL" prefWidth="180"/>
                    <TableColumn fx:id="colCategory" text="Category" prefWidth="130"/>
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="160"/>
                </columns>
                <placeholder>
                    <Label text="Aucune formation trouvée"/>
                </placeholder>
            </TableView>

            <HBox alignment="CENTER_LEFT">
                <Label fx:id="lblTotal" text="Total: 0"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="🔄 Rafraîchir" onAction="#handleRefresh"
                        styleClass="btn-refresh"/>
            </HBox>
        </VBox>

        <!-- ADD/EDIT FORM (hidden by default) -->
        <VBox fx:id="formSection" spacing="15" visible="false" managed="false">
            <Label fx:id="lblFormTitle" text="➕ Ajouter Formation"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <VBox spacing="15" styleClass="form-card" maxWidth="600">
                <padding><Insets top="25" bottom="25" left="25" right="25"/></padding>

                <Label text="Titre:" styleClass="form-label"/>
                <TextField fx:id="tfTitle" promptText="Entrer le titre"
                           styleClass="form-input"/>

                <Label text="Description:" styleClass="form-label"/>
                <TextArea fx:id="taDescription" promptText="Entrer la description"
                          prefRowCount="4" wrapText="true" styleClass="form-input"/>

                <Label text="URL Vidéo:" styleClass="form-label"/>
                <TextField fx:id="tfVideoUrl" promptText="Entrer l'URL vidéo"
                           styleClass="form-input"/>

                <Label text="Catégorie:" styleClass="form-label"/>
                <ComboBox fx:id="cbCategory" promptText="Choisir catégorie"
                          prefWidth="300" styleClass="form-input"/>

                <Label fx:id="lblError" text="" style="-fx-text-fill: red;"/>

                <HBox spacing="15">
                    <padding><Insets top="10"/></padding>
                    <Button fx:id="btnSave" text="✅ Enregistrer"
                            onAction="#handleSave" styleClass="btn-save"/>
                    <Button text="🔄 Effacer" onAction="#handleClear"
                            styleClass="btn-clear"/>
                    <Button text="↩️ Retour" onAction="#showTable"
                            styleClass="btn-back"/>
                </HBox>
            </VBox>
        </VBox>

    </StackPane>

</VBox>