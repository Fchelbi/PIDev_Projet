<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.FormationListController"
      spacing="15" styleClass="page-container">
    <padding><Insets top="10" bottom="10" left="10" right="10"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="📚 All Formations"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <TextField fx:id="tfSearch" promptText="🔍 Search formations..."
                   prefWidth="250" onKeyReleased="#handleSearch"
                   styleClass="search-field"/>
    </HBox>

    <Separator/>

    <!-- Table -->
    <TableView fx:id="tvFormations" VBox.vgrow="ALWAYS"
               styleClass="formations-table">
        <columns>
            <TableColumn fx:id="colTitle" text="Title" prefWidth="180"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="250"/>
            <TableColumn fx:id="colVideoUrl" text="Video URL" prefWidth="180"/>
            <TableColumn fx:id="colCategory" text="Category" prefWidth="130"/>
            <TableColumn fx:id="colActions" text="Actions" prefWidth="160"/>
        </columns>

        <placeholder>
            <Label text="No formations found"
                   style="-fx-font-size: 14px; -fx-text-fill: #636e72;"/>
        </placeholder>
    </TableView>

    <!-- Bottom Bar -->
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="bottom-bar">
        <Label fx:id="lblTotal" text="Total: 0 formations"
               style="-fx-font-size: 13px; -fx-text-fill: #636e72;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="🔄 Refresh" onAction="#handleRefresh"
                styleClass="btn-refresh"/>
    </HBox>

</VBox>