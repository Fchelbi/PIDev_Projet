<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.ResetPassword"
           prefHeight="700.0" prefWidth="1100.0"
           style="-fx-background-color: #F2D0BC;">

    <HBox alignment="CENTER" spacing="0">

        <!-- ═══ LEFT PANEL ═══ -->
        <VBox alignment="CENTER" spacing="30" prefWidth="440"
              style="-fx-background-color: linear-gradient(to bottom, #4A6FA5, #3A5A90);
                     -fx-padding: 70 55;">

            <VBox alignment="CENTER" spacing="10">
                <StackPane prefWidth="90" prefHeight="90" alignment="CENTER">
                    <Circle radius="45" fill="rgba(255,255,255,0.12)"/>
                    <Circle radius="32" fill="rgba(232,149,109,0.25)"/>
                    <Label text="🛡️" style="-fx-font-size: 38px;"/>
                </StackPane>
                <Label text="EchoCare"
                       style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: white;"/>
                <Label text="NOUVEAU MOT DE PASSE"
                       style="-fx-font-size: 10px; -fx-text-fill: #F5C87A;
                              -fx-letter-spacing: 2; -fx-font-weight: 600;"/>
            </VBox>

            <VBox alignment="CENTER" spacing="10">
                <Label text="Sécurisez votre compte"
                       style="-fx-font-size: 22px; -fx-font-weight: 300; -fx-text-fill: white;"/>
                <Label text="Créez un mot de passe fort pour protéger votre compte EchoCare"
                       style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.72);"
                       wrapText="true" textAlignment="CENTER" maxWidth="330"/>
            </VBox>

            <!-- Password rules -->
            <VBox spacing="12"
                  style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 12;
                         -fx-padding: 20; -fx-border-color: rgba(255,255,255,0.15);
                         -fx-border-radius: 12; -fx-border-width: 1;">
                <Label text="RÈGLES DU MOT DE PASSE"
                       style="-fx-text-fill: #F5C87A; -fx-font-size: 10px;
                              -fx-font-weight: 700; -fx-letter-spacing: 1;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="✓" style="-fx-text-fill: #74C69D; -fx-font-weight: 700;"/>
                    <Label text="Minimum 8 caractères"
                           style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12px;"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="✓" style="-fx-text-fill: #74C69D; -fx-font-weight: 700;"/>
                    <Label text="Au moins 1 majuscule (A-Z)"
                           style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12px;"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="✓" style="-fx-text-fill: #74C69D; -fx-font-weight: 700;"/>
                    <Label text="Au moins 1 chiffre (0-9)"
                           style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12px;"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="✓" style="-fx-text-fill: #74C69D; -fx-font-weight: 700;"/>
                    <Label text="1 caractère spécial (!@#$%...)"
                           style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12px;"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- ═══ RIGHT PANEL ═══ -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #FDFAF6; -fx-padding: 60 80;">

            <VBox alignment="CENTER_LEFT" spacing="22" maxWidth="400">

                <VBox spacing="6">
                    <Label text="Nouveau mot de passe"
                           style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: #3D5A8A;"/>
                    <Label text="Entrez le code reçu et choisissez un nouveau mot de passe fort"
                           style="-fx-font-size: 13px; -fx-text-fill: #7B9ED9;" wrapText="true"/>
                </VBox>

                <!-- Code -->
                <VBox spacing="8">
                    <Label text="Code de récupération"
                           style="-fx-font-size: 13px; -fx-text-fill: #5A6A8A; -fx-font-weight: 600;"/>
                    <TextField fx:id="tfCode" promptText="Entrez le code reçu par email"
                               style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                      -fx-border-radius: 10; -fx-background-radius: 10;
                                      -fx-border-width: 1.5; -fx-padding: 13 16;
                                      -fx-font-size: 14px; -fx-font-weight: 600;
                                      -fx-text-fill: #3D5A8A; -fx-letter-spacing: 3;
                                      -fx-prompt-text-fill: #C0D3EB;"/>
                </VBox>

                <!-- Nouveau mdp -->
                <VBox spacing="8">
                    <Label text="Nouveau mot de passe"
                           style="-fx-font-size: 13px; -fx-text-fill: #5A6A8A; -fx-font-weight: 600;"/>
                    <PasswordField fx:id="pfNewPassword" promptText="Min 8 chars, 1 majuscule, 1 chiffre, 1 spécial"
                                   style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                          -fx-border-radius: 10; -fx-background-radius: 10;
                                          -fx-border-width: 1.5; -fx-padding: 13 16;
                                          -fx-font-size: 14px; -fx-text-fill: #3D5A8A;
                                          -fx-prompt-text-fill: #C0D3EB;"/>
                    <!-- Indicateur de force -->
                    <Label fx:id="lblPassStrength" text=""
                           style="-fx-font-size: 11px; -fx-text-fill: #7B9ED9;"/>
                </VBox>

                <!-- Confirmation -->
                <VBox spacing="8">
                    <Label text="Confirmer le mot de passe"
                           style="-fx-font-size: 13px; -fx-text-fill: #5A6A8A; -fx-font-weight: 600;"/>
                    <PasswordField fx:id="pfConfirm" promptText="Répétez votre mot de passe"
                                   style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                          -fx-border-radius: 10; -fx-background-radius: 10;
                                          -fx-border-width: 1.5; -fx-padding: 13 16;
                                          -fx-font-size: 14px; -fx-text-fill: #3D5A8A;
                                          -fx-prompt-text-fill: #C0D3EB;"/>
                </VBox>

                <Button text="🔐  Réinitialiser le mot de passe" onAction="#handleReset"
                        maxWidth="Infinity"
                        style="-fx-background-color: #E8956D; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-font-weight: 700; -fx-padding: 15;
                               -fx-background-radius: 10; -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(232,149,109,0.35), 12, 0, 0, 4);"/>

                <HBox alignment="CENTER">
                    <Button text="← Retour à la connexion" onAction="#handleBack"
                            style="-fx-background-color: transparent; -fx-text-fill: #7B9ED9;
                                   -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: transparent;"/>
                </HBox>

            </VBox>
        </VBox>
    </HBox>
</StackPane>
