<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.ResetPassword"
           prefHeight="650.0" prefWidth="900.0"
           style="-fx-background-color: #F8F9FC;">

    <HBox alignment="CENTER" spacing="0">

        <!-- Left Panel -->
        <VBox alignment="CENTER" spacing="30" prefWidth="400"
              style="-fx-background-color: linear-gradient(to bottom right, #D4EDDA, #A7D8B0); -fx-padding: 60;">
            <StackPane>
                <Circle radius="70" fill="WHITE" opacity="0.4"/>
                <Label text="🔒" style="-fx-font-size: 48px;"/>
            </StackPane>
            <VBox alignment="CENTER" spacing="12">
                <Label text="Nouveau mot de passe" textFill="#4A5568"
                       style="-fx-font-size: 26px; -fx-font-weight: 600;" wrapText="true" textAlignment="CENTER">
                    <font><Font name="System Bold" size="26"/></font>
                </Label>
                <Label text="Entrez le code reçu et choisissez un nouveau mot de passe."
                       textFill="#5A6578" style="-fx-font-size: 14px; -fx-opacity: 0.9;"
                       wrapText="true" textAlignment="CENTER" maxWidth="300"/>
            </VBox>
        </VBox>

        <!-- Right Panel -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-padding: 60;">
            <VBox alignment="CENTER_LEFT" spacing="25" maxWidth="400">

                <VBox spacing="8">
                    <Label text="Réinitialisation"
                           style="-fx-font-size: 32px; -fx-font-weight: 600; -fx-text-fill: #4A5568;">
                        <font><Font name="System Bold" size="32"/></font>
                    </Label>
                    <Label text="Saisissez le code et votre nouveau mot de passe"
                           style="-fx-font-size: 14px; -fx-text-fill: #A0AEC0;"/>
                </VBox>

                <VBox spacing="10">
                    <Label text="Code de vérification"
                           style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: 500;"/>
                    <TextField fx:id="tfCode" promptText="Entrez le code à 6 chiffres"
                               style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0;
                                      -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1.5;
                                      -fx-padding: 14; -fx-font-size: 18px; -fx-font-weight: bold;
                                      -fx-alignment: CENTER; -fx-prompt-text-fill: #CBD5E0;"/>
                </VBox>

                <VBox spacing="10">
                    <Label text="Nouveau mot de passe"
                           style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: 500;"/>
                    <PasswordField fx:id="pfNewPassword" promptText="Minimum 6 caractères"
                                   style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0;
                                          -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1.5;
                                          -fx-padding: 14; -fx-font-size: 14px; -fx-prompt-text-fill: #CBD5E0;"/>
                </VBox>

                <VBox spacing="10">
                    <Label text="Confirmer le mot de passe"
                           style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: 500;"/>
                    <PasswordField fx:id="pfConfirm" promptText="Répétez le mot de passe"
                                   style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0;
                                          -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1.5;
                                          -fx-padding: 14; -fx-font-size: 14px; -fx-prompt-text-fill: #CBD5E0;"/>
                </VBox>

                <Button text="✅ Réinitialiser" onAction="#handleReset"
                        maxWidth="Infinity"
                        style="-fx-background-color: linear-gradient(to right, #81C995, #A7D8B0);
                               -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600;
                               -fx-padding: 16; -fx-background-radius: 8; -fx-cursor: hand;">
                    <font><Font name="System Bold" size="15"/></font>
                </Button>

                <HBox alignment="CENTER">
                    <Hyperlink text="← Retour à la connexion" onAction="#handleBack"
                               style="-fx-text-fill: #A0AEC0; -fx-font-size: 13px;"/>
                </HBox>

            </VBox>
        </VBox>
    </HBox>
</StackPane>
