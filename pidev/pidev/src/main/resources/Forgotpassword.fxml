<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.ForgotPassword"
           prefHeight="600.0" prefWidth="900.0"
           style="-fx-background-color: #F8F9FC;">

    <HBox alignment="CENTER" spacing="0">

        <!-- Left Panel -->
        <VBox alignment="CENTER" spacing="30" prefWidth="400"
              style="-fx-background-color: linear-gradient(to bottom right, #C3CEF0, #EABDD4); -fx-padding: 60;">
            <StackPane>
                <Circle radius="70" fill="WHITE" opacity="0.4"/>
                <Label text="🔑" style="-fx-font-size: 48px;"/>
            </StackPane>
            <VBox alignment="CENTER" spacing="12">
                <Label text="Mot de passe oublié" textFill="#4A5568"
                       style="-fx-font-size: 28px; -fx-font-weight: 600;" wrapText="true" textAlignment="CENTER">
                    <font><Font name="System Bold" size="28"/></font>
                </Label>
                <Label text="Entrez votre email et nous vous enverrons un code de réinitialisation."
                       textFill="#5A6578" style="-fx-font-size: 14px; -fx-opacity: 0.9;"
                       wrapText="true" textAlignment="CENTER" maxWidth="300"/>
            </VBox>
        </VBox>

        <!-- Right Panel -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-padding: 60;">
            <VBox alignment="CENTER_LEFT" spacing="30" maxWidth="400">

                <VBox spacing="8">
                    <Label text="Réinitialisation"
                           style="-fx-font-size: 32px; -fx-font-weight: 600; -fx-text-fill: #4A5568;">
                        <font><Font name="System Bold" size="32"/></font>
                    </Label>
                    <Label text="Un code vous sera envoyé par email"
                           style="-fx-font-size: 14px; -fx-text-fill: #A0AEC0;"/>
                </VBox>

                <VBox spacing="10">
                    <Label text="Adresse email"
                           style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: 500;"/>
                    <TextField fx:id="tfEmail" promptText="vous@exemple.com"
                               style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0;
                                      -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1.5;
                                      -fx-padding: 14; -fx-font-size: 14px; -fx-prompt-text-fill: #CBD5E0;"/>
                </VBox>

                <Button text="📧 Envoyer le code" onAction="#handleSendCode"
                        maxWidth="Infinity"
                        style="-fx-background-color: linear-gradient(to right, #A7B5E0, #D4A5BD);
                               -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600;
                               -fx-padding: 16; -fx-background-radius: 8; -fx-cursor: hand;">
                    <font><Font name="System Bold" size="15"/></font>
                </Button>

                <HBox alignment="CENTER">
                    <Hyperlink text="← Retour à la connexion" onAction="#handleBack"
                               style="-fx-text-fill: #A0AEC0; -fx-font-size: 13px;"/>
                </HBox>

            </VBox>
        </VBox>
    </HBox>
</StackPane>
