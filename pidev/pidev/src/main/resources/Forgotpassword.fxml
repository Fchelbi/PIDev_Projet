<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.ForgotPassword"
           prefHeight="680.0" prefWidth="1100.0"
           style="-fx-background-color: #F2D0BC;">

    <HBox alignment="CENTER" spacing="0">

        <!-- ═══ LEFT PANEL ═══ -->
        <VBox alignment="CENTER" spacing="30" prefWidth="440"
              style="-fx-background-color: linear-gradient(to bottom, #4A6FA5, #3A5A90);
                     -fx-padding: 70 55;">

            <VBox alignment="CENTER" spacing="10">
                <StackPane prefWidth="90" prefHeight="90" alignment="CENTER">
                    <Circle radius="45" fill="rgba(255,255,255,0.12)"/>
                    <Circle radius="32" fill="rgba(232,149,109,0.25)"/>
                    <Label text="🔑" style="-fx-font-size: 38px;"/>
                </StackPane>
                <Label text="EchoCare"
                       style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: white;"/>
                <Label text="RÉCUPÉRATION DE COMPTE"
                       style="-fx-font-size: 10px; -fx-text-fill: #F5C87A;
                              -fx-letter-spacing: 2; -fx-font-weight: 600;"/>
            </VBox>

            <VBox alignment="CENTER" spacing="10">
                <Label text="Mot de passe oublié ?"
                       style="-fx-font-size: 24px; -fx-font-weight: 300; -fx-text-fill: white;"
                       wrapText="true" textAlignment="CENTER"/>
                <Label text="Entrez votre email et nous vous enverrons un code de réinitialisation sécurisé"
                       style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.72);"
                       wrapText="true" textAlignment="CENTER" maxWidth="330"/>
            </VBox>

            <!-- Steps -->
            <VBox spacing="14" style="-fx-padding: 10 0 0 0;">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane prefWidth="30" prefHeight="30">
                        <Circle radius="15" fill="#E8956D"/>
                        <Label text="1" style="-fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                    </StackPane>
                    <Label text="Entrez votre adresse email"
                           style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane prefWidth="30" prefHeight="30">
                        <Circle radius="15" fill="rgba(255,255,255,0.2)"/>
                        <Label text="2" style="-fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                    </StackPane>
                    <Label text="Recevez le code par email"
                           style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 12px;"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane prefWidth="30" prefHeight="30">
                        <Circle radius="15" fill="rgba(255,255,255,0.2)"/>
                        <Label text="3" style="-fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 13px;"/>
                    </StackPane>
                    <Label text="Créez votre nouveau mot de passe"
                           style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 12px;"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- ═══ RIGHT PANEL ═══ -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #FDFAF6; -fx-padding: 70 80;">

            <VBox alignment="CENTER_LEFT" spacing="28" maxWidth="400">

                <VBox spacing="6">
                    <Label text="Réinitialisation"
                           style="-fx-font-size: 30px; -fx-font-weight: 700; -fx-text-fill: #3D5A8A;"/>
                    <Label text="Nous vous enverrons un code de récupération"
                           style="-fx-font-size: 13px; -fx-text-fill: #7B9ED9;"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="Adresse email"
                           style="-fx-font-size: 13px; -fx-text-fill: #5A6A8A; -fx-font-weight: 600;"/>
                    <TextField fx:id="tfEmail" promptText="vous@exemple.com"
                               style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                      -fx-border-radius: 10; -fx-background-radius: 10;
                                      -fx-border-width: 1.5; -fx-padding: 14 16;
                                      -fx-font-size: 14px; -fx-text-fill: #3D5A8A;
                                      -fx-prompt-text-fill: #C0D3EB;"/>
                </VBox>

                <Button text="📧  Envoyer le code de récupération" onAction="#handleSendCode"
                        maxWidth="Infinity"
                        style="-fx-background-color: #4A6FA5; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-font-weight: 700; -fx-padding: 15;
                               -fx-background-radius: 10; -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(74,111,165,0.35), 12, 0, 0, 4);"/>

                <!-- Info -->
                <HBox spacing="10" alignment="CENTER_LEFT"
                      style="-fx-background-color: #EEF4FF; -fx-background-radius: 10; -fx-padding: 14;">
                    <Label text="💡" style="-fx-font-size: 16px;"/>
                    <Label text="Vérifiez aussi vos spams si vous ne recevez pas l'email"
                           style="-fx-font-size: 12px; -fx-text-fill: #4A6FA5;"
                           wrapText="true"/>
                </HBox>

                <HBox alignment="CENTER">
                    <Button text="← Retour à la connexion" onAction="#handleBack"
                            style="-fx-background-color: transparent; -fx-text-fill: #7B9ED9;
                                   -fx-font-size: 13px; -fx-cursor: hand;
                                   -fx-border-color: transparent;"/>
                </HBox>

            </VBox>
        </VBox>
    </HBox>
</StackPane>
