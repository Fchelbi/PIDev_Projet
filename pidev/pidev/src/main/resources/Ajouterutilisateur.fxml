<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="0" style="-fx-background-color: #F8F9FC; -fx-padding: 0;" prefWidth="500"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.AjouterUtilisateur">

    <HBox style="-fx-background-color: linear-gradient(to right, #A7B5E0, #D4A5BD);
                 -fx-padding: 20; -fx-background-radius: 0;" alignment="CENTER">
        <Label text="➕ Ajouter un Utilisateur" textFill="WHITE">
            <font><Font name="System Bold" size="20"/></font></Label>
    </HBox>

    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 30;">
        <VBox spacing="6"><Label text="Nom *" style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: 500;"/>
            <TextField fx:id="tfNom" promptText="Nom de famille"
                       style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8;
                              -fx-background-radius: 8; -fx-border-width: 1.5; -fx-padding: 12; -fx-font-size: 14px;"/></VBox>

        <VBox spacing="6"><Label text="Prénom *" style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: 500;"/>
            <TextField fx:id="tfPrenom" promptText="Prénom"
                       style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8;
                              -fx-background-radius: 8; -fx-border-width: 1.5; -fx-padding: 12; -fx-font-size: 14px;"/></VBox>

        <VBox spacing="6"><Label text="Email *" style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: 500;"/>
            <TextField fx:id="tfEmail" promptText="exemple@email.com"
                       style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8;
                              -fx-background-radius: 8; -fx-border-width: 1.5; -fx-padding: 12; -fx-font-size: 14px;"/></VBox>

        <VBox spacing="6"><Label text="Mot de passe *" style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: 500;"/>
            <PasswordField fx:id="pfMdp" promptText="Minimum 6 caractères"
                           style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8;
                                  -fx-background-radius: 8; -fx-border-width: 1.5; -fx-padding: 12; -fx-font-size: 14px;"/></VBox>

        <VBox spacing="6"><Label text="Téléphone" style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: 500;"/>
            <TextField fx:id="tfTel" promptText="12345678"
                       style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8;
                              -fx-background-radius: 8; -fx-border-width: 1.5; -fx-padding: 12; -fx-font-size: 14px;"/></VBox>

        <VBox spacing="6"><Label text="Rôle *" style="-fx-font-size: 13px; -fx-text-fill: #718096; -fx-font-weight: 500;"/>
            <ComboBox fx:id="cbRole" maxWidth="Infinity"
                      style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8;
                             -fx-background-radius: 8; -fx-border-width: 1.5; -fx-padding: 8; -fx-font-size: 14px;"/></VBox>

        <Label text="* Champs obligatoires" style="-fx-text-fill: #A0AEC0; -fx-font-size: 11px;"/>

        <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
            <Button text="✅ Ajouter" onAction="#handleAjouter" prefWidth="150"
                    style="-fx-background-color: #81C995; -fx-text-fill: white; -fx-padding: 12;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand; -fx-background-radius: 8;"/>
            <Button text="❌ Annuler" onAction="#handleAnnuler" prefWidth="150"
                    style="-fx-background-color: #F0F3F8; -fx-text-fill: #718096; -fx-padding: 12;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand; -fx-background-radius: 8;"/>
        </HBox>
    </VBox>
</VBox>