<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="400.0" prefWidth="600.0"
      style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MainMenuController">
    <children>
        <Label text="Système de Gestion PI-DEV" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
        <Button text="Espace Administrateur" onAction="#openAdmin" prefWidth="250.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;"/>
        <Button text="Espace Psychologue" onAction="#openPsy" prefWidth="250.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 14px;"/>
        <Button text="Espace Client (Patient)" onAction="#openPatient" prefWidth="250.0" style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-size: 14px;"/>
    </children>
</VBox>