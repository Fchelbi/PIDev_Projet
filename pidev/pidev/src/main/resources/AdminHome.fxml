<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AdminHome">

    <!-- HEADER -->
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 15;" spacing="20.0" alignment="CENTER_LEFT">
            <Label text="🛠️ ESPACE ADMINISTRATEUR" textFill="WHITE">
                <font><Font name="System Bold" size="22.0" /></font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblWelcome" text="Bienvenue Admin" textFill="WHITE">
                <font><Font size="14.0" /></font>
            </Label>
            <Button text="Déconnexion" onAction="#handleLogout"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 8 15; -fx-cursor: hand;">
            </Button>
        </HBox>
    </top>

    <!-- SIDEBAR (Menu) -->
    <left>
        <VBox style="-fx-background-color: #34495e; -fx-padding: 20;" spacing="10.0" prefWidth="250.0">
            <Label text="MENU" textFill="WHITE">
                <font><Font name="System Bold" size="16.0" /></font>
            </Label>
            <Separator />

            <!-- Menu Items -->
            <Button fx:id="btnDashboard" text="📊 Dashboard" maxWidth="Infinity" onAction="#showDashboard"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 12; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-cursor: hand;">
            </Button>

            <Button fx:id="btnUtilisateurs" text="👥 Utilisateurs" maxWidth="Infinity" onAction="#showUtilisateurs"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-padding: 12; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-cursor: hand;">
            </Button>

            <Button text="📅 Rendez-vous" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-padding: 12; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-cursor: hand;">
            </Button>

            <Button text="📈 Statistiques" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-padding: 12; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-cursor: hand;">
            </Button>
        </VBox>
    </left>

    <!-- CONTENU PRINCIPAL (Center) -->
    <center>
        <StackPane fx:id="contentArea">
            <!-- Dashboard Content (Default) -->
            <VBox fx:id="dashboardPane" style="-fx-background-color: #ecf0f1; -fx-padding: 30;" spacing="25.0">

                <Label text="Tableau de bord">
                    <font><Font name="System Bold" size="28.0" /></font>
                </Label>

                <!-- Statistiques Cards -->
                <HBox spacing="25.0" alignment="CENTER">

                    <!-- Card Patients -->
                    <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 3);"
                          alignment="CENTER" spacing="12.0" prefWidth="220.0">
                        <Label text="👤" style="-fx-font-size: 42px;" />
                        <Label fx:id="lblNbPatients" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
                        <Label text="Patients" style="-fx-font-size: 15px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" />
                    </VBox>

                    <!-- Card Coaches -->
                    <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 3);"
                          alignment="CENTER" spacing="12.0" prefWidth="220.0">
                        <Label text="💪" style="-fx-font-size: 42px;" />
                        <Label fx:id="lblNbCoaches" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" />
                        <Label text="Coaches" style="-fx-font-size: 15px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" />
                    </VBox>

                    <!-- Card Admins -->
                    <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 3);"
                          alignment="CENTER" spacing="12.0" prefWidth="220.0">
                        <Label text="🔧" style="-fx-font-size: 42px;" />
                        <Label fx:id="lblNbAdmins" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #e67e22;" />
                        <Label text="Administrateurs" style="-fx-font-size: 15px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" />
                    </VBox>

                    <!-- Card Total -->
                    <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 3);"
                          alignment="CENTER" spacing="12.0" prefWidth="220.0">
                        <Label text="👥" style="-fx-font-size: 42px;" />
                        <Label fx:id="lblNbTotal" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #9b59b6;" />
                        <Label text="Total Utilisateurs" style="-fx-font-size: 15px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" />
                    </VBox>

                </HBox>

                <!-- Actions rapides -->
                <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25;">
                    <Label text="⚡ Actions rapides">
                        <font><Font name="System Bold" size="20.0" /></font>
                    </Label>

                    <HBox spacing="15.0">
                        <Button text="➕ Nouvel utilisateur" onAction="#showUtilisateurs"
                                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 14 22; -fx-font-size: 14px; -fx-cursor: hand; -fx-background-radius: 8;">
                        </Button>
                        <Button text="👁️ Voir tous les utilisateurs" onAction="#showUtilisateurs"
                                style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 14 22; -fx-font-size: 14px; -fx-cursor: hand; -fx-background-radius: 8;">
                        </Button>
                        <Button text="🔄 Actualiser" onAction="#refreshStats"
                                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 14 22; -fx-font-size: 14px; -fx-cursor: hand; -fx-background-radius: 8;">
                        </Button>
                    </HBox>
                </VBox>

                <!-- Activités récentes -->
                <HBox spacing="25.0" alignment="CENTER">

                    <!-- Left: Activities -->
                    <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25;" HBox.hgrow="ALWAYS">
                        <Label text="📋 Activités récentes">
                            <font><Font name="System Bold" size="20.0" /></font>
                        </Label>
                        <Separator />
                        <Label text="• Nouvel utilisateur inscrit: Mohamed Ali (Patient)" style="-fx-text-fill: #34495e; -fx-font-size: 13px;" />
                        <Label text="• Modification profil: Sarah Ben Salah (Coach)" style="-fx-text-fill: #34495e; -fx-font-size: 13px;" />
                        <Label text="• Suppression compte: Test User" style="-fx-text-fill: #34495e; -fx-font-size: 13px;" />
                    </VBox>

                    <!-- Right: Pie Chart -->
                    <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25;" alignment="CENTER" prefWidth="400.0">
                        <Label text="📊 Répartition par Rôle">
                            <font><Font name="System Bold" size="20.0" /></font>
                        </Label>
                        <Separator prefWidth="350.0" />
                        <PieChart fx:id="pieChartRoles" prefHeight="300.0" prefWidth="350.0" legendVisible="true" />
                    </VBox>

                </HBox>

            </VBox>
        </StackPane>
    </center>

</BorderPane>
