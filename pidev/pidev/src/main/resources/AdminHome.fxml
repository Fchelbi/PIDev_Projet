<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="800.0" prefWidth="1400.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AdminHome"
            style="-fx-background-color: #F8F9FC;">

    <!-- TOP NAVBAR -->
    <top>
        <HBox style="-fx-background-color: white; -fx-padding: 18 30;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 12, 0, 0, 2);"
              spacing="25" alignment="CENTER_LEFT">
            <HBox spacing="15" alignment="CENTER">
                <StackPane>
                    <Circle radius="22" fill="linear-gradient(to bottom right, #A7B5E0, #D4A5BD)"/>
                    <SVGPath content="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"
                             fill="WHITE" scaleX="0.8" scaleY="0.8"/>
                </StackPane>
                <Label text="Admin Panel"
                       style="-fx-font-size: 20px; -fx-font-weight: 600; -fx-text-fill: #4A5568;">
                    <font><Font name="System Bold" size="20"/></font>
                </Label>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="15" alignment="CENTER">
                <Label fx:id="lblWelcome" text="Admin"
                       style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4A5568;"/>

                <StackPane>
                    <Circle fx:id="headerAvatarCircle" radius="20"
                            fill="linear-gradient(to bottom right, #A7B5E0, #D4A5BD)"/>
                    <ImageView fx:id="imgHeaderPhoto" fitWidth="40" fitHeight="40"
                               preserveRatio="false" smooth="true" visible="false">
                        <clip>
                            <Circle radius="20" centerX="20" centerY="20"/>
                        </clip>
                    </ImageView>
                    <Label fx:id="lblHeaderAvatar" text="A" textFill="WHITE"
                           style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                </StackPane>

                <Button text="🚪" onAction="#handleLogout"
                        style="-fx-background-color: transparent; -fx-text-fill: #A0AEC0;
                               -fx-font-size: 18px; -fx-padding: 5 10; -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox style="-fx-background-color: white; -fx-padding: 25 0;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 12, 0, 2, 0);"
              spacing="8" prefWidth="260">

            <VBox spacing="6" style="-fx-padding: 0 20 20 20;">
                <Label text="NAVIGATION"
                       style="-fx-text-fill: #CBD5E0; -fx-font-size: 11px;
                              -fx-font-weight: 600; -fx-padding: 0 10;"/>
            </VBox>

            <!-- Dashboard -->
            <HBox fx:id="btnDashboard" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#showDashboard"
                  style="-fx-padding: 14 25;
                         -fx-background-color: linear-gradient(to right, rgba(167,181,224,0.12), transparent);
                         -fx-border-color: transparent transparent transparent #A7B5E0;
                         -fx-border-width: 0 0 0 3; -fx-cursor: hand;">
                <Label text="📊" style="-fx-font-size: 16px;"/>
                <Label text="Dashboard"
                       style="-fx-text-fill: #9FAEE0; -fx-font-size: 14px; -fx-font-weight: 600;"/>
            </HBox>

            <!-- Utilisateurs -->
            <HBox fx:id="btnUtilisateurs" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#showUtilisateurs"
                  style="-fx-padding: 14 25; -fx-cursor: hand;">
                <Label text="👥" style="-fx-font-size: 16px;"/>
                <Label text="Utilisateurs"
                       style="-fx-text-fill: #A0AEC0; -fx-font-size: 14px; -fx-font-weight: 500;"/>
            </HBox>

            <!-- Mon Profil -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#showProfil"
                  style="-fx-padding: 14 25; -fx-cursor: hand;">
                <Label text="👤" style="-fx-font-size: 16px;"/>
                <Label text="Mon Profil"
                       style="-fx-text-fill: #A0AEC0; -fx-font-size: 14px; -fx-font-weight: 500;"/>
            </HBox>

            <!-- Rendez-vous -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-padding: 14 25; -fx-cursor: hand;">
                <Label text="📅" style="-fx-font-size: 16px;"/>
                <Label text="Rendez-vous"
                       style="-fx-text-fill: #A0AEC0; -fx-font-size: 14px; -fx-font-weight: 500;"/>
            </HBox>

            <!-- ✅ Carte Psychologues -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#showMap"
                  style="-fx-padding: 14 25; -fx-cursor: hand;">
                <Label text="🗺️" style="-fx-font-size: 16px;"/>
                <Label text="Carte Psychologues"
                       style="-fx-text-fill: #A0AEC0; -fx-font-size: 14px; -fx-font-weight: 500;"/>
            </HBox>

            <!-- ✅ Générer Rapport -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#showRapport"
                  style="-fx-padding: 14 25; -fx-cursor: hand;">
                <Label text="📄" style="-fx-font-size: 16px;"/>
                <Label text="Rapport PDF"
                       style="-fx-text-fill: #A0AEC0; -fx-font-size: 14px; -fx-font-weight: 500;"/>
            </HBox>

            <!-- Statistiques -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-padding: 14 25; -fx-cursor: hand;">
                <Label text="📈" style="-fx-font-size: 16px;"/>
                <Label text="Statistiques"
                       style="-fx-text-fill: #A0AEC0; -fx-font-size: 14px; -fx-font-weight: 500;"/>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator style="-fx-background-color: #EDF2F7; -fx-padding: 0 20;"/>

            <VBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: linear-gradient(to bottom, #D6DDEF, #EABDD4);
                         -fx-background-radius: 15; -fx-padding: 20;">
                <Label text="💖" style="-fx-font-size: 28px;"/>
                <Label text="Version 1.0"
                       style="-fx-font-size: 11px; -fx-font-weight: 600; -fx-text-fill: #4A5568;"/>
            </VBox>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-padding: 30;">

            <VBox fx:id="dashboardPane" spacing="25">

                <!-- Page Header -->
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <VBox>
                        <Label text="Vue d'ensemble"
                               style="-fx-font-size: 28px; -fx-font-weight: 600; -fx-text-fill: #4A5568;">
                            <font><Font name="System Bold" size="28"/></font>
                        </Label>
                        <Label text="Bienvenue sur votre dashboard"
                               style="-fx-font-size: 14px; -fx-text-fill: #A0AEC0; -fx-padding: 4 0 0 0;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="🔄 Actualiser" onAction="#refreshStats"
                            style="-fx-background-color: white; -fx-text-fill: #A0AEC0;
                                   -fx-padding: 10 20; -fx-font-size: 13px; -fx-font-weight: 600;
                                   -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1.5;"/>
                </HBox>

                <!-- Stats Cards -->
                <HBox spacing="20" alignment="CENTER">

                    <!-- Patients -->
                    <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 24;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 12, 0, 0, 3);"
                          alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS">
                        <StackPane>
                            <Circle radius="28" fill="#C3CEF0" opacity="0.4"/>
                            <Label text="👤" style="-fx-font-size: 28px;"/>
                        </StackPane>
                        <Label fx:id="lblNbPatients" text="0"
                               style="-fx-font-size: 32px; -fx-font-weight: 700; -fx-text-fill: #4A5568;"/>
                        <Label text="Patients"
                               style="-fx-text-fill: #A0AEC0; -fx-font-size: 13px; -fx-font-weight: 500;"/>
                    </VBox>

                    <!-- Coaches -->
                    <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 24;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 12, 0, 0, 3);"
                          alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS">
                        <StackPane>
                            <Circle radius="28" fill="#EABDD4" opacity="0.4"/>
                            <Label text="💪" style="-fx-font-size: 28px;"/>
                        </StackPane>
                        <Label fx:id="lblNbCoaches" text="0"
                               style="-fx-font-size: 32px; -fx-font-weight: 700; -fx-text-fill: #4A5568;"/>
                        <Label text="Coaches"
                               style="-fx-text-fill: #A0AEC0; -fx-font-size: 13px; -fx-font-weight: 500;"/>
                    </VBox>

                    <!-- Admins -->
                    <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 24;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 12, 0, 0, 3);"
                          alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS">
                        <StackPane>
                            <Circle radius="28" fill="#B8C4E8" opacity="0.4"/>
                            <Label text="👑" style="-fx-font-size: 28px;"/>
                        </StackPane>
                        <Label fx:id="lblNbAdmins" text="0"
                               style="-fx-font-size: 32px; -fx-font-weight: 700; -fx-text-fill: #4A5568;"/>
                        <Label text="Admins"
                               style="-fx-text-fill: #A0AEC0; -fx-font-size: 13px; -fx-font-weight: 500;"/>
                    </VBox>

                    <!-- Total -->
                    <VBox style="-fx-background-color: linear-gradient(to bottom right, #C3CEF0, #EABDD4);
                                 -fx-background-radius: 16; -fx-padding: 24;"
                          alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS">
                        <Label text="✨" style="-fx-font-size: 28px;"/>
                        <Label fx:id="lblNbTotal" text="0"
                               style="-fx-font-size: 32px; -fx-font-weight: 700; -fx-text-fill: #4A5568;"/>
                        <Label text="Total"
                               style="-fx-text-fill: #5A6578; -fx-font-size: 13px; -fx-font-weight: 500;"/>
                    </VBox>
                </HBox>

                <!-- Charts & Actions -->
                <HBox spacing="20">

                    <!-- Pie Chart -->
                    <VBox spacing="15" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 12, 0, 0, 3);">
                        <Label text="📊 Répartition"
                               style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #4A5568;">
                            <font><Font name="System Bold" size="18"/></font>
                        </Label>
                        <PieChart fx:id="pieChartRoles" prefHeight="300" legendSide="BOTTOM"/>
                    </VBox>

                    <!-- Quick Actions -->
                    <VBox spacing="15" prefWidth="300"
                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 12, 0, 0, 3);">
                        <Label text="⚡ Actions"
                               style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #4A5568;">
                            <font><Font name="System Bold" size="18"/></font>
                        </Label>
                        <VBox spacing="10">
                            <Button text="➕ Nouvel utilisateur" maxWidth="Infinity"
                                    onAction="#showUtilisateurs"
                                    style="-fx-background-color: #A7B5E0; -fx-text-fill: white;
                                           -fx-padding: 14; -fx-font-size: 14px; -fx-font-weight: 600;
                                           -fx-cursor: hand; -fx-background-radius: 8;"/>
                            <Button text="🗺️ Carte Psychologues" maxWidth="Infinity"
                                    onAction="#showMap"
                                    style="-fx-background-color: #D4A5BD; -fx-text-fill: white;
                                           -fx-padding: 14; -fx-font-size: 14px; -fx-font-weight: 600;
                                           -fx-cursor: hand; -fx-background-radius: 8;"/>
                            <Button text="📄 Générer Rapport" maxWidth="Infinity"
                                    onAction="#showRapport"
                                    style="-fx-background-color: white; -fx-text-fill: #A0AEC0;
                                           -fx-padding: 14; -fx-font-size: 14px; -fx-font-weight: 600;
                                           -fx-cursor: hand; -fx-background-radius: 8;
                                           -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1.5;"/>
                        </VBox>
                    </VBox>
                </HBox>

            </VBox>
        </StackPane>
    </center>

</BorderPane>
