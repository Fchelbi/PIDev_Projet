<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="750.0" prefWidth="1300.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.PatientHome"
            style="-fx-background-color: #F8F9FC;">

    <!-- HEADER -->
    <top>
        <HBox style="-fx-background-color: white; -fx-padding: 18 30;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 12, 0, 0, 2);"
              spacing="25" alignment="CENTER_LEFT">
            <HBox spacing="15" alignment="CENTER">
                <StackPane>
                    <Circle radius="22"
                            fill="linear-gradient(to bottom right, #E0A7B5, #D4C5A5)"/>
                    <Label text="🏥" style="-fx-font-size: 18px;"/>
                </StackPane>
                <Label text="Espace Patient"
                       style="-fx-font-size: 20px; -fx-font-weight: 600; -fx-text-fill: #4A5568;">
                    <font><Font name="System Bold" size="20"/></font>
                </Label>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="15" alignment="CENTER">
                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label fx:id="lblWelcome" text="Patient"
                           style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4A5568;"/>
                    <Label text="Patient"
                           style="-fx-font-size: 12px; -fx-text-fill: #A0AEC0;"/>
                </VBox>

                <StackPane>
                    <Circle fx:id="headerAvatarCircle" radius="20"
                            fill="linear-gradient(to bottom right, #E0A7B5, #D4C5A5)"/>
                    <ImageView fx:id="imgHeaderPhoto" fitWidth="40" fitHeight="40"
                               preserveRatio="false" smooth="true" visible="false">
                        <clip>
                            <Circle radius="20" centerX="20" centerY="20"/>
                        </clip>
                    </ImageView>
                    <Label fx:id="lblAvatarHeader" text="P" textFill="WHITE"
                           style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                </StackPane>

                <Button text="🚪" onAction="#handleLogout"
                        style="-fx-background-color: transparent; -fx-text-fill: #A0AEC0;
                               -fx-font-size: 18px; -fx-padding: 5 10; -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox style="-fx-background-color: white; -fx-padding: 25 0;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 12, 0, 2, 0);"
              spacing="8" prefWidth="250">

            <VBox spacing="6" style="-fx-padding: 0 20 20 20;">
                <Label text="NAVIGATION"
                       style="-fx-text-fill: #CBD5E0; -fx-font-size: 11px;
                              -fx-font-weight: 600; -fx-padding: 0 10;"/>
            </VBox>

            <!-- Accueil -->
            <Button text="🏠  Accueil" maxWidth="Infinity" onAction="#showAccueil"
                    style="-fx-background-color: linear-gradient(to right, rgba(224,167,181,0.15), transparent);
                           -fx-text-fill: #D4889A; -fx-padding: 14 25; -fx-alignment: CENTER_LEFT;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-background-radius: 0;
                           -fx-border-color: transparent transparent transparent #E0A7B5;
                           -fx-border-width: 0 0 0 3; -fx-cursor: hand;"/>

            <!-- Mon Profil -->
            <Button text="👤  Mon Profil" maxWidth="Infinity" onAction="#showProfil"
                    style="-fx-background-color: transparent; -fx-text-fill: #A0AEC0;
                           -fx-padding: 14 25; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px;
                           -fx-font-weight: 500; -fx-background-radius: 0; -fx-cursor: hand;"/>

            <!-- Mes Rendez-vous -->
            <Button text="📅  Mes Rendez-vous" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #A0AEC0;
                           -fx-padding: 14 25; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px;
                           -fx-font-weight: 500; -fx-background-radius: 0; -fx-cursor: hand;"/>

            <!-- Coaches Disponibles -->
            <Button text="💪  Coaches Disponibles" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #A0AEC0;
                           -fx-padding: 14 25; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px;
                           -fx-font-weight: 500; -fx-background-radius: 0; -fx-cursor: hand;"/>

            <!-- Mon Historique -->
            <Button text="📊  Mon Historique" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #A0AEC0;
                           -fx-padding: 14 25; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px;
                           -fx-font-weight: 500; -fx-background-radius: 0; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator style="-fx-background-color: #EDF2F7; -fx-padding: 0 20;"/>

            <VBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: linear-gradient(to bottom, #F0D6DC, #EDE0D0);
                         -fx-background-radius: 15; -fx-padding: 20;">
                <Label text="🏥" style="-fx-font-size: 28px;"/>
                <Label text="Votre santé compte"
                       style="-fx-font-size: 12px; -fx-font-weight: 600; -fx-text-fill: #4A5568;"/>
            </VBox>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-padding: 30;">

            <VBox fx:id="accueilPane" spacing="25">

                <!-- Page Header -->
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <VBox>
                        <Label text="Bienvenue dans votre espace"
                               style="-fx-font-size: 28px; -fx-font-weight: 600; -fx-text-fill: #4A5568;">
                            <font><Font name="System Bold" size="28"/></font>
                        </Label>
                        <Label text="Gérez vos rendez-vous et suivez votre progression"
                               style="-fx-font-size: 14px; -fx-text-fill: #A0AEC0; -fx-padding: 4 0 0 0;"/>
                    </VBox>
                </HBox>

                <!-- Stats Cards -->
                <HBox spacing="20" alignment="CENTER">

                    <!-- Prochains RDV -->
                    <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 28;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 12, 0, 0, 3);"
                          alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS">
                        <StackPane>
                            <Circle radius="30" fill="#E0A7B5" opacity="0.3"/>
                            <Label text="📅" style="-fx-font-size: 30px;"/>
                        </StackPane>
                        <Label fx:id="lblNbRdv" text="0"
                               style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-text-fill: #4A5568;"/>
                        <Label text="Rendez-vous à venir"
                               style="-fx-font-size: 14px; -fx-text-fill: #A0AEC0; -fx-font-weight: 500;"/>
                    </VBox>

                    <!-- Séances effectuées -->
                    <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 28;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 12, 0, 0, 3);"
                          alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS">
                        <StackPane>
                            <Circle radius="30" fill="#81C995" opacity="0.3"/>
                            <Label text="✅" style="-fx-font-size: 30px;"/>
                        </StackPane>
                        <Label fx:id="lblNbSeances" text="0"
                               style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-text-fill: #4A5568;"/>
                        <Label text="Séances Effectuées"
                               style="-fx-font-size: 14px; -fx-text-fill: #A0AEC0; -fx-font-weight: 500;"/>
                    </VBox>

                    <!-- Mon Coach -->
                    <VBox style="-fx-background-color: linear-gradient(to bottom right, #E0A7B5, #D4C5A5);
                                 -fx-background-radius: 16; -fx-padding: 28;
                                 -fx-effect: dropshadow(gaussian, rgba(224,167,181,0.25), 12, 0, 0, 3);"
                          alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS">
                        <Label text="💪" style="-fx-font-size: 30px;"/>
                        <Label text="Mon Coach"
                               style="-fx-font-size: 16px; -fx-font-weight: 700; -fx-text-fill: #4A5568;"/>
                        <Label text="Trouver un coach"
                               style="-fx-font-size: 13px; -fx-text-fill: #5A6578; -fx-opacity: 0.9;"/>
                    </VBox>
                </HBox>

                <!-- Actions + Infos -->
                <HBox spacing="20">

                    <!-- Actions rapides -->
                    <VBox spacing="15" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 12, 0, 0, 3);">
                        <Label text="⚡ Actions rapides"
                               style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #4A5568;">
                            <font><Font name="System Bold" size="18"/></font>
                        </Label>
                        <VBox spacing="10">
                            <Button text="📅  Prendre un RDV" maxWidth="Infinity"
                                    style="-fx-background-color: #E0A7B5; -fx-text-fill: white;
                                           -fx-padding: 14; -fx-font-size: 14px; -fx-font-weight: 600;
                                           -fx-cursor: hand; -fx-background-radius: 8;"/>
                            <Button text="💪  Trouver un Coach" maxWidth="Infinity"
                                    style="-fx-background-color: #81C995; -fx-text-fill: white;
                                           -fx-padding: 14; -fx-font-size: 14px; -fx-font-weight: 600;
                                           -fx-cursor: hand; -fx-background-radius: 8;"/>
                            <Button text="👤  Mon Profil" maxWidth="Infinity" onAction="#showProfil"
                                    style="-fx-background-color: #D4C5A5; -fx-text-fill: white;
                                           -fx-padding: 14; -fx-font-size: 14px; -fx-font-weight: 600;
                                           -fx-cursor: hand; -fx-background-radius: 8;"/>
                        </VBox>
                    </VBox>

                    <!-- Mes Informations -->
                    <VBox spacing="15" prefWidth="350"
                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 12, 0, 0, 3);">
                        <Label text="📋 Mes Informations"
                               style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #4A5568;">
                            <font><Font name="System Bold" size="18"/></font>
                        </Label>
                        <Separator style="-fx-background-color: #EDF2F7;"/>
                        <VBox spacing="12">
                            <HBox spacing="10">
                                <Label text="Nom:"
                                       style="-fx-font-weight: 600; -fx-text-fill: #718096; -fx-font-size: 13px;"/>
                                <Label fx:id="lblNom" text="-"
                                       style="-fx-text-fill: #4A5568; -fx-font-size: 13px;"/>
                            </HBox>
                            <HBox spacing="10">
                                <Label text="Email:"
                                       style="-fx-font-weight: 600; -fx-text-fill: #718096; -fx-font-size: 13px;"/>
                                <Label fx:id="lblEmail" text="-"
                                       style="-fx-text-fill: #4A5568; -fx-font-size: 13px;"/>
                            </HBox>
                            <HBox spacing="10">
                                <Label text="Téléphone:"
                                       style="-fx-font-weight: 600; -fx-text-fill: #718096; -fx-font-size: 13px;"/>
                                <Label fx:id="lblTel" text="-"
                                       style="-fx-text-fill: #4A5568; -fx-font-size: 13px;"/>
                            </HBox>
                        </VBox>
                        <Button text="Voir profil complet →" onAction="#showProfil"
                                style="-fx-background-color: transparent; -fx-text-fill: #D4889A;
                                       -fx-font-size: 13px; -fx-font-weight: 600;
                                       -fx-cursor: hand; -fx-padding: 5 0;"/>
                    </VBox>
                </HBox>

                <!-- Notification -->
                <HBox style="-fx-background-color: #FDF2F8; -fx-background-radius: 12; -fx-padding: 18;"
                      spacing="12" alignment="CENTER_LEFT">
                    <Label text="💡" style="-fx-font-size: 22px;"/>
                    <VBox spacing="4">
                        <Label text="Bienvenue sur votre espace personnel !"
                               style="-fx-font-weight: 600; -fx-text-fill: #D4889A; -fx-font-size: 14px;"/>
                        <Label text="Gérez vos rendez-vous, consultez vos séances et contactez votre coach."
                               style="-fx-text-fill: #718096; -fx-font-size: 13px;" wrapText="true"/>
                    </VBox>
                </HBox>

            </VBox>
        </StackPane>
    </center>

</BorderPane>