<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.FormationController"
      spacing="15">
    <padding><Insets top="10" bottom="10" left="10" right="10"/></padding>

    <Label text="✏️ Edit Formation"
           style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
    <Separator/>

    <VBox spacing="15" styleClass="form-card" maxWidth="600">
        <padding><Insets top="25" bottom="25" left="25" right="25"/></padding>

        <Label text="Title:" styleClass="form-label"/>
        <TextField fx:id="tfTitle" styleClass="form-input"/>

        <Label text="Description:" styleClass="form-label"/>
        <TextArea fx:id="taDescription" prefRowCount="4"
                  wrapText="true" styleClass="form-input"/>

        <Label text="Video URL:" styleClass="form-label"/>
        <TextField fx:id="tfVideoUrl" styleClass="form-input"/>

        <Label text="Category:" styleClass="form-label"/>
        <ComboBox fx:id="cbCategory" prefWidth="300" styleClass="form-input"/>

        <Label fx:id="lblError" text="" style="-fx-text-fill: red;"/>

        <HBox spacing="15">
            <padding><Insets top="10"/></padding>
            <Button text="💾 Update" onAction="#handleUpdate" styleClass="btn-save"/>
            <Button text="↩️ Cancel" onAction="#handleBackToList" styleClass="btn-back"/>
        </HBox>
    </VBox>

</VBox>