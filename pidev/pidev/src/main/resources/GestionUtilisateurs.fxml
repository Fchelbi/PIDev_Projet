<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="20" style="-fx-background-color: #F8F9FC; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.GestionUtilisateurs">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="👥 Gestion des Utilisateurs" style="-fx-font-size: 28px; -fx-font-weight: 600; -fx-text-fill: #4A5568;">
            <font><Font name="System Bold" size="28"/></font></Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🔄 Actualiser" onAction="#refreshTable"
                style="-fx-background-color: white; -fx-text-fill: #A0AEC0; -fx-padding: 10 18;
                       -fx-font-size: 13px; -fx-font-weight: 600; -fx-cursor: hand; -fx-background-radius: 8;
                       -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-border-width: 1.5;"/>
        <Button text="➕ Ajouter" onAction="#showAjouterDialog"
                style="-fx-background-color: linear-gradient(to right, #A7B5E0, #D4A5BD); -fx-text-fill: white;
                       -fx-padding: 10 18; -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand; -fx-background-radius: 8;"/>
    </HBox>

    <HBox spacing="15" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 12, 0, 0, 3);">
        <Label text="🔍" style="-fx-font-size: 16px;"/>
        <TextField fx:id="tfSearch" promptText="Rechercher..." prefWidth="300"
                   style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8;
                          -fx-background-radius: 8; -fx-border-width: 1.5; -fx-padding: 10; -fx-font-size: 13px;
                          -fx-prompt-text-fill: #CBD5E0;"/>
        <ComboBox fx:id="cbFilterRole" prefWidth="160"
                  style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8;
                         -fx-background-radius: 8; -fx-font-size: 13px;"/>
        <Button text="Rechercher" onAction="#handleSearch"
                style="-fx-background-color: #A7B5E0; -fx-text-fill: white; -fx-padding: 8 16;
                       -fx-font-size: 13px; -fx-cursor: hand; -fx-background-radius: 8;"/>
        <Button text="Réinitialiser" onAction="#resetFilters"
                style="-fx-background-color: #F0F3F8; -fx-text-fill: #718096; -fx-padding: 8 16;
                       -fx-font-size: 13px; -fx-cursor: hand; -fx-background-radius: 8;"/>
    </HBox>

    <TableView fx:id="tableUsers" style="-fx-background-color: white; -fx-background-radius: 12;" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="Nom" prefWidth="160">
                <cellValueFactory><PropertyValueFactory property="nom"/></cellValueFactory></TableColumn>
            <TableColumn text="Prénom" prefWidth="160">
                <cellValueFactory><PropertyValueFactory property="prenom"/></cellValueFactory></TableColumn>
            <TableColumn text="Email" prefWidth="220">
                <cellValueFactory><PropertyValueFactory property="email"/></cellValueFactory></TableColumn>
            <TableColumn text="Téléphone" prefWidth="120" style="-fx-alignment: CENTER;">
                <cellValueFactory><PropertyValueFactory property="num_tel"/></cellValueFactory></TableColumn>
            <TableColumn text="Rôle" prefWidth="100" style="-fx-alignment: CENTER;">
                <cellValueFactory><PropertyValueFactory property="role"/></cellValueFactory></TableColumn>
            <TableColumn fx:id="colActions" text="Actions" prefWidth="200" style="-fx-alignment: CENTER;" sortable="false"/>
        </columns>
        <placeholder>
            <VBox alignment="CENTER" spacing="10" style="-fx-padding: 40;">
                <Label text="📋" style="-fx-font-size: 48px;"/>
                <Label text="Aucun utilisateur trouvé" style="-fx-font-size: 16px; -fx-text-fill: #A0AEC0;"/>
            </VBox>
        </placeholder>
    </TableView>

    <HBox spacing="20" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12;">
        <Label fx:id="lblTotalUsers" text="Total: 0" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4A5568;"/>
        <Separator orientation="VERTICAL"/>
        <Label fx:id="lblFilteredCount" text="Affichés: 0" style="-fx-font-size: 13px; -fx-text-fill: #A0AEC0;"/>
    </HBox>
</VBox>