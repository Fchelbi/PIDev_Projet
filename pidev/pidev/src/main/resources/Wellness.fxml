<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.web.*?>

<!--
    Wellness.fxml
    UI construite programmatiquement dans WellnessController
    pour éviter les erreurs FXML complexes
-->
<VBox fx:id="rootPane"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.Wellnesscontroller"
      prefWidth="900" prefHeight="700"
      style="-fx-background-color: #F8F4EF;">
</VBox>
