<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<VBox spacing="0" style="-fx-background-color: #F2EDE8;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.MapController">

    <!-- Header -->
    <HBox spacing="15" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-padding: 18 25;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
        <StackPane prefWidth="40" prefHeight="40">
            <Circle radius="20" fill="#FFF0E0"/>
            <Label text="🗺️" style="-fx-font-size: 18px;"/>
        </StackPane>
        <VBox spacing="2">
            <Label text="Carte des Psychologues"
                   style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #3D5A8A;"/>
            <Label text="Trouvez un psychologue proche de vous — Tunisie"
                   style="-fx-font-size: 11px; -fx-text-fill: #7B9ED9;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblResultCount" text=""
               style="-fx-font-size: 11px; -fx-text-fill: #E8956D; -fx-font-weight: 600;"/>
    </HBox>

    <!-- Search bar -->
    <HBox spacing="12" alignment="CENTER_LEFT"
          style="-fx-padding: 15 25; -fx-background-color: white;
                 -fx-border-color: transparent transparent #F0EDE8 transparent; -fx-border-width: 1;">
        <Label text="🔍" style="-fx-font-size: 14px;"/>
        <TextField fx:id="tfSearch"
                   promptText="Rechercher un psychologue, spécialité, ville..."
                   style="-fx-background-color: #F7F5F2; -fx-border-color: #E2DDD8;
                          -fx-border-radius: 8; -fx-background-radius: 8;
                          -fx-padding: 9 14; -fx-font-size: 13px;"
                   HBox.hgrow="ALWAYS"/>
        <Button text="Rechercher" onAction="#handleSearch"
                style="-fx-background-color: #E8956D; -fx-text-fill: white;
                       -fx-font-size: 12px; -fx-font-weight: 600;
                       -fx-padding: 9 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="Tout afficher" onAction="#resetFilters"
                style="-fx-background-color: #4A6FA5; -fx-text-fill: white;
                       -fx-font-size: 12px; -fx-padding: 9 16;
                       -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>

    <!-- Content: List + Detail -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- Left: ListView -->
        <VBox prefWidth="380" minWidth="320"
              style="-fx-background-color: #F7F5F2;
                     -fx-border-color: transparent #E2DDD8 transparent transparent;
                     -fx-border-width: 1;">
            <Label text="RÉSULTATS"
                   style="-fx-padding: 12 20 8 20; -fx-font-size: 10px;
                          -fx-font-weight: 600; -fx-letter-spacing: 2;
                          -fx-text-fill: #7B9ED9;"/>
            <ListView fx:id="listPlaces" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
        </VBox>

        <!-- Right: Detail Card -->
        <VBox fx:id="detailCard" HBox.hgrow="ALWAYS" spacing="20"
              style="-fx-background-color: #FDFAF6; -fx-padding: 40;"
              alignment="TOP_LEFT">

            <!-- Placeholder quand rien sélectionné -->
            <VBox alignment="CENTER" spacing="15" VBox.vgrow="ALWAYS">
                <Label text="🗺️" style="-fx-font-size: 52px;"/>
                <Label text="Sélectionnez un psychologue"
                       style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #3D5A8A;"/>
                <Label text="Cliquez sur un nom — Google Maps s'ouvre automatiquement 🗺️"
                       wrapText="true" textAlignment="CENTER"
                       style="-fx-font-size: 12px; -fx-text-fill: #7B9ED9;"/>
            </VBox>

            <!-- ✅ Detail card avec bouton Google Maps -->
            <VBox spacing="16" visible="false" managed="false"
                  style="-fx-background-color: #FDFAF6; -fx-background-radius: 14;
                         -fx-border-color: #D5E3F5; -fx-border-radius: 14; -fx-border-width: 1.5;
                         -fx-padding: 25;">

                <Label fx:id="lblSelectedName"
                       style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #3D5A8A;"/>

                <VBox spacing="10">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="📍" style="-fx-font-size: 14px;"/>
                        <Label fx:id="lblSelectedAddress"
                               style="-fx-font-size: 13px; -fx-text-fill: #5A6A8A;" wrapText="true"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="⭐" style="-fx-font-size: 14px;"/>
                        <Label fx:id="lblSelectedRating"
                               style="-fx-font-size: 13px; -fx-text-fill: #E8956D; -fx-font-weight: 600;"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="🕐" style="-fx-font-size: 14px;"/>
                        <Label fx:id="lblSelectedStatus"
                               style="-fx-font-size: 13px; -fx-font-weight: 600;"/>
                    </HBox>
                </VBox>

                <!-- ✅ Bouton Google Maps -->
                <Button text="🗺️  Ouvrir dans Google Maps" onAction="#openInGoogleMaps"
                        maxWidth="Infinity"
                        style="-fx-background-color: #E8956D; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: 700;
                               -fx-padding: 12 20; -fx-background-radius: 10;
                               -fx-cursor: hand;"/>

                <Label text="💡 Cliquer sur un nom dans la liste ouvre aussi Maps directement"
                       wrapText="true"
                       style="-fx-font-size: 11px; -fx-text-fill: #BDD0EE; -fx-font-style: italic;"/>
            </VBox>

        </VBox>
    </HBox>

</VBox>
