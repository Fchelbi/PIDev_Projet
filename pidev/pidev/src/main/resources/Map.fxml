<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.web.*?>

<VBox spacing="0" style="-fx-background-color: #FAF7F5;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.Map">

    <!-- Header -->
    <HBox spacing="15" alignment="CENTER_LEFT"
          style="-fx-background-color: WHITE;
                 -fx-padding: 18 25;
                 -fx-effect: dropshadow(gaussian, rgba(124,107,196,0.08), 12, 0, 0, 3);">
        <Label text="🗺️" style="-fx-font-size: 22px;"/>
        <VBox spacing="2">
            <Label text="Trouver un Psychologue"
                   style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #4A3B6B;">
                <font><Font name="System Bold" size="20"/></font>
            </Label>
            <Label text="Trouvez un professionnel près de chez vous"
                   style="-fx-font-size: 12px; -fx-text-fill: #A99BBE;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblResultCount" text="0 résultat(s)"
               style="-fx-font-size: 13px; -fx-text-fill: #8B7FA3; -fx-font-weight: 600;
                      -fx-background-color: #F5F0FA; -fx-padding: 8 18; -fx-background-radius: 20;"/>
    </HBox>

    <HBox spacing="0" VBox.vgrow="ALWAYS">

        <!-- Left Panel - Search & List -->
        <VBox spacing="0" prefWidth="340"
              style="-fx-background-color: WHITE;
                     -fx-effect: dropshadow(gaussian, rgba(124,107,196,0.05), 10, 0, 3, 0);">

            <!-- Search -->
            <VBox spacing="10" style="-fx-padding: 18;">
                <HBox spacing="8">
                    <TextField fx:id="tfSearch" promptText="Ville ou adresse..."
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: #F8F5FC;
                                      -fx-border-color: #E8DFF5;
                                      -fx-border-radius: 10;
                                      -fx-background-radius: 10;
                                      -fx-border-width: 1.5;
                                      -fx-padding: 10 14;
                                      -fx-font-size: 13px;
                                      -fx-prompt-text-fill: #CBBFE0;"/>
                    <Button text="🔍" onAction="#handleSearch"
                            style="-fx-background-color: linear-gradient(to right, #7C6BC4, #9B8DD4);
                                   -fx-text-fill: white;
                                   -fx-font-size: 14px;
                                   -fx-padding: 10 14;
                                   -fx-background-radius: 10;
                                   -fx-cursor: hand;"/>
                </HBox>

                <!-- Filter Buttons -->
                <HBox spacing="6">
                    <Button text="✅ Ouverts" onAction="#filterOpen"
                            style="-fx-background-color: #F0FAF4;
                                   -fx-text-fill: #5FAD6F;
                                   -fx-font-size: 11px;
                                   -fx-font-weight: 600;
                                   -fx-padding: 6 12;
                                   -fx-background-radius: 15;
                                   -fx-cursor: hand;"/>
                    <Button text="⭐ Mieux notés" onAction="#filterTopRated"
                            style="-fx-background-color: #FFF5F7;
                                   -fx-text-fill: #E8B4C8;
                                   -fx-font-size: 11px;
                                   -fx-font-weight: 600;
                                   -fx-padding: 6 12;
                                   -fx-background-radius: 15;
                                   -fx-cursor: hand;"/>
                    <Button text="🔄 Tous" onAction="#resetFilters"
                            style="-fx-background-color: #F5F0FA;
                                   -fx-text-fill: #8B7FA3;
                                   -fx-font-size: 11px;
                                   -fx-font-weight: 600;
                                   -fx-padding: 6 12;
                                   -fx-background-radius: 15;
                                   -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <Separator style="-fx-background-color: #E8DFF5;"/>

            <!-- Places List -->
            <ListView fx:id="listPlaces" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: WHITE;
                             -fx-border-color: transparent;"/>

            <!-- Detail Card -->
            <VBox fx:id="detailCard" spacing="8" visible="false" managed="false"
                  style="-fx-background-color: linear-gradient(to bottom right, #F5F0FA, #FFF5F7);
                         -fx-padding: 18;
                         -fx-border-color: #E8DFF5;
                         -fx-border-width: 1 0 0 0;">
                <Label fx:id="lblSelectedName" text=""
                       style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #4A3B6B;"/>
                <Label fx:id="lblSelectedAddress" text=""
                       style="-fx-font-size: 12px; -fx-text-fill: #8B7FA3;"/>
                <HBox spacing="15">
                    <Label fx:id="lblSelectedRating" text=""
                           style="-fx-font-size: 13px; -fx-text-fill: #E8B4C8; -fx-font-weight: 600;"/>
                    <Label fx:id="lblSelectedStatus" text=""
                           style="-fx-font-size: 13px; -fx-font-weight: 600;"/>
                </HBox>
                <Button text="📅 Prendre Rendez-vous"
                        maxWidth="Infinity"
                        style="-fx-background-color: linear-gradient(to right, #7C6BC4, #C4A8E0);
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: 600;
                               -fx-padding: 10;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;"/>
            </VBox>
        </VBox>

        <!-- Right - Map -->
        <StackPane HBox.hgrow="ALWAYS" style="-fx-padding: 0;">
            <WebView fx:id="mapWebView"/>
        </StackPane>

    </HBox>
</VBox>