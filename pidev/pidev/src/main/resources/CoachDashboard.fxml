<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.CoachController"
            prefWidth="1150" prefHeight="720"
            style="-fx-background-color: #f0f2f5;">

    <top>
        <HBox alignment="CENTER_RIGHT" spacing="15"
              style="-fx-background-color: linear-gradient(to right, #6c5ce7, #a29bfe);
                     -fx-padding: 12 20;">
            <Label text="🏥 EchoCare — Espace Coach"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"
                   HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Label text="👨‍⚕️" style="-fx-font-size: 20px;"/>
            <Label fx:id="lblCoachName" text="Dr. Coach"
                   style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="5" prefWidth="230"
              style="-fx-background-color: linear-gradient(to bottom, #2d3436, #3d3d3d);">
            <padding><Insets top="20" bottom="20" left="10" right="10"/></padding>

            <Label text="👨‍⚕️" style="-fx-font-size: 40px;"
                   alignment="CENTER" maxWidth="Infinity"/>
            <Label text="Espace Coach"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #a29bfe;"
                   alignment="CENTER" maxWidth="Infinity"/>

            <Separator style="-fx-background-color: #636e72;"/>

            <Label text="NAVIGATION"
                   style="-fx-text-fill: #636e72; -fx-font-size: 11px;
                          -fx-padding: 10 0 5 15;"/>

            <Button fx:id="btnAccueil"
                    text="   🏠  Tableau de Bord"
                    onAction="#showAccueil"
                    styleClass="sidebar-btn"
                    maxWidth="Infinity" alignment="CENTER_LEFT"/>

            <Button fx:id="btnFormations"
                    text="   📚  Formations"
                    onAction="#showFormations"
                    styleClass="sidebar-btn"
                    maxWidth="Infinity" alignment="CENTER_LEFT"/>

            <Button fx:id="btnResults"
                    text="   📊  Résultats Patients"
                    onAction="#showAllResults"
                    styleClass="sidebar-btn"
                    maxWidth="Infinity" alignment="CENTER_LEFT"/>

            <Button fx:id="btnPatients"
                    text="   👥  Suivi Patients"
                    onAction="#showPatients"
                    styleClass="sidebar-btn"
                    maxWidth="Infinity" alignment="CENTER_LEFT"/>

            <VBox VBox.vgrow="ALWAYS"/>

            <Separator style="-fx-background-color: #636e72;"/>

            <Button text="   🚪  Déconnexion"
                    onAction="#handleLogout"
                    styleClass="sidebar-btn-logout"
                    maxWidth="Infinity" alignment="CENTER_LEFT"/>
            <Button fx:id="btnFormations"
                    text="   📚  Mes Formations"
                    onAction="#showFormations"
                    styleClass="sidebar-btn"
                    maxWidth="Infinity" alignment="CENTER_LEFT"/>

            <!-- NEW: Coach can manage his own formations -->
            <Button text="   ⚙️  Gérer Formations"
                    onAction="#showManageFormations"
                    styleClass="sidebar-btn"
                    maxWidth="Infinity" alignment="CENTER_LEFT"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color: #f0f2f5;">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
        </StackPane>
    </center>

</BorderPane>