<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.VerifyCode"
           prefHeight="700.0" prefWidth="1200.0"
           style="-fx-background-color: #F2D0BC;">

    <HBox alignment="CENTER" spacing="0">

        <!-- ═══ LEFT PANEL ═══ -->
        <VBox alignment="CENTER" spacing="35" prefWidth="480"
              style="-fx-background-color: linear-gradient(to bottom, #4A6FA5, #3A5A90);
                     -fx-padding: 70 60;">

            <!-- Logo -->
            <VBox alignment="CENTER" spacing="8">
                <StackPane prefWidth="90" prefHeight="90" alignment="CENTER">
                    <Circle radius="45" fill="rgba(255,255,255,0.12)"/>
                    <Circle radius="34" fill="rgba(255,255,255,0.18)"/>
                    <Label text="🔐" style="-fx-font-size: 40px;"/>
                </StackPane>
                <Label text="EchoCare"
                       style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: white;"/>
                <Label text="VÉRIFICATION SÉCURISÉE"
                       style="-fx-font-size: 10px; -fx-text-fill: #F5C87A;
                              -fx-letter-spacing: 2; -fx-font-weight: 600;"/>
            </VBox>

            <!-- Description -->
            <VBox alignment="CENTER" spacing="10">
                <Label text="Code de sécurité"
                       style="-fx-font-size: 28px; -fx-font-weight: 300; -fx-text-fill: white;"/>
                <Label text="Un code à 6 chiffres a été envoyé à votre adresse email"
                       style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.75);"
                       wrapText="true" textAlignment="CENTER" maxWidth="340"/>
            </VBox>

            <!-- Instructions -->
            <VBox spacing="16" style="-fx-padding: 20 0 0 0;">
                <HBox spacing="14" alignment="CENTER_LEFT">
                    <StackPane prefWidth="32" prefHeight="32">
                        <Circle radius="16" fill="rgba(245,200,122,0.2)"/>
                        <Label text="✉️" style="-fx-font-size: 14px;"/>
                    </StackPane>
                    <Label text="Vérifiez votre boîte mail"
                           style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 13px;"/>
                </HBox>
                <HBox spacing="14" alignment="CENTER_LEFT">
                    <StackPane prefWidth="32" prefHeight="32">
                        <Circle radius="16" fill="rgba(245,200,122,0.2)"/>
                        <Label text="⏱️" style="-fx-font-size: 14px;"/>
                    </StackPane>
                    <Label text="Code valide pendant 10 minutes"
                           style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 13px;"/>
                </HBox>
                <HBox spacing="14" alignment="CENTER_LEFT">
                    <StackPane prefWidth="32" prefHeight="32">
                        <Circle radius="16" fill="rgba(245,200,122,0.2)"/>
                        <Label text="🔒" style="-fx-font-size: 14px;"/>
                    </StackPane>
                    <Label text="Ne partagez jamais ce code"
                           style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 13px;"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- ═══ RIGHT PANEL ═══ -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #FDFAF6; -fx-padding: 70 80;">

            <VBox alignment="CENTER_LEFT" spacing="30" maxWidth="420">

                <!-- Titre -->
                <VBox spacing="6">
                    <Label text="Entrez votre code"
                           style="-fx-font-size: 30px; -fx-font-weight: 700; -fx-text-fill: #3D5A8A;"/>
                    <Label text="Saisissez le code à 6 chiffres reçu par email"
                           style="-fx-font-size: 13px; -fx-text-fill: #7B9ED9;"/>
                </VBox>

                <!-- Timer badge -->
                <HBox alignment="CENTER">
                    <Label fx:id="lblTimer"
                           text="⏱️  Code valide : 10:00"
                           style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4A6FA5;
                                  -fx-background-color: #EEF4FF; -fx-padding: 10 22;
                                  -fx-background-radius: 20;
                                  -fx-border-color: #D5E3F5; -fx-border-radius: 20; -fx-border-width: 1;"/>
                </HBox>

                <!-- Code digits -->
                <VBox spacing="10" alignment="CENTER">
                    <Label text="Votre code de vérification"
                           style="-fx-font-size: 12px; -fx-text-fill: #7B9ED9; -fx-font-weight: 500;"/>
                    <HBox spacing="10" alignment="CENTER">
                        <TextField fx:id="digit1" maxWidth="58" prefHeight="68"
                                   style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                          -fx-border-radius: 12; -fx-background-radius: 12;
                                          -fx-border-width: 2; -fx-font-size: 28px; -fx-font-weight: 700;
                                          -fx-text-fill: #3D5A8A;" alignment="CENTER"/>
                        <TextField fx:id="digit2" maxWidth="58" prefHeight="68"
                                   style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                          -fx-border-radius: 12; -fx-background-radius: 12;
                                          -fx-border-width: 2; -fx-font-size: 28px; -fx-font-weight: 700;
                                          -fx-text-fill: #3D5A8A;" alignment="CENTER"/>
                        <TextField fx:id="digit3" maxWidth="58" prefHeight="68"
                                   style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                          -fx-border-radius: 12; -fx-background-radius: 12;
                                          -fx-border-width: 2; -fx-font-size: 28px; -fx-font-weight: 700;
                                          -fx-text-fill: #3D5A8A;" alignment="CENTER"/>
                        <Label text="—" style="-fx-font-size: 22px; -fx-text-fill: #C0D3EB;"/>
                        <TextField fx:id="digit4" maxWidth="58" prefHeight="68"
                                   style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                          -fx-border-radius: 12; -fx-background-radius: 12;
                                          -fx-border-width: 2; -fx-font-size: 28px; -fx-font-weight: 700;
                                          -fx-text-fill: #3D5A8A;" alignment="CENTER"/>
                        <TextField fx:id="digit5" maxWidth="58" prefHeight="68"
                                   style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                          -fx-border-radius: 12; -fx-background-radius: 12;
                                          -fx-border-width: 2; -fx-font-size: 28px; -fx-font-weight: 700;
                                          -fx-text-fill: #3D5A8A;" alignment="CENTER"/>
                        <TextField fx:id="digit6" maxWidth="58" prefHeight="68"
                                   style="-fx-background-color: #F6F3F0; -fx-border-color: #D5E3F5;
                                          -fx-border-radius: 12; -fx-background-radius: 12;
                                          -fx-border-width: 2; -fx-font-size: 28px; -fx-font-weight: 700;
                                          -fx-text-fill: #3D5A8A;" alignment="CENTER"/>
                    </HBox>
                </VBox>

                <!-- Bouton vérifier -->
                <Button text="✓  Vérifier le code" onAction="#handleVerify" maxWidth="Infinity"
                        style="-fx-background-color: #E8956D; -fx-text-fill: white;
                               -fx-font-size: 15px; -fx-font-weight: 700; -fx-padding: 16;
                               -fx-background-radius: 10; -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(232,149,109,0.35), 12, 0, 0, 4);"/>

                <!-- Separator -->
                <HBox alignment="CENTER" spacing="12">
                    <Line endX="100" stroke="#E8E0D8" strokeWidth="1"/>
                    <Label text="ou" style="-fx-text-fill: #C0D3EB; -fx-font-size: 12px;"/>
                    <Line endX="100" stroke="#E8E0D8" strokeWidth="1"/>
                </HBox>

                <!-- Resend + Back -->
                <VBox spacing="10" alignment="CENTER">
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Pas reçu le code ?"
                               style="-fx-text-fill: #A0B8D8; -fx-font-size: 13px;"/>
                        <Hyperlink fx:id="linkResend" text="Renvoyer le code"
                                   onAction="#handleResend"
                                   style="-fx-text-fill: #4A6FA5; -fx-font-weight: 700;
                                          -fx-font-size: 13px; -fx-border-color: transparent;"/>
                    </HBox>
                    <Button text="← Retour à la connexion" onAction="#handleBack"
                            style="-fx-background-color: transparent; -fx-text-fill: #A0B8D8;
                                   -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 5 0;"/>
                </VBox>

            </VBox>
        </VBox>
    </HBox>
</StackPane>
