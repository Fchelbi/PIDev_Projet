<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER" prefHeight="400.0" prefWidth="600.0"
      xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.projet.gui.patient.PsyDispoController" style="-fx-padding: 20;">

    <Label text="Tableau de bord Psychologue" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TableView fx:id="tableRdv" prefHeight="250.0">
        <columns>
            <TableColumn fx:id="colPatient" text="ID Patient" prefWidth="100"/>
            <TableColumn fx:id="colDate" text="Date prévue" prefWidth="250"/>
            <TableColumn fx:id="colStatut" text="Statut actuel" prefWidth="150"/>
        </columns>
    </TableView>

    <HBox spacing="20" alignment="CENTER">
        <Button text="Accepter" onAction="#handleAccepter"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Refuser (À replanifier)" onAction="#handleRefuser"
                style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
    <Button text="⬅ Retour au Menu" onAction="#retourMenu"
            style="-fx-background-color: #607D8B; -fx-text-fill: white;"
            AnchorPane.topAnchor="10.0" AnchorPane.leftAnchor="10.0" />
</VBox>