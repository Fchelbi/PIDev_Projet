<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<BorderPane prefHeight="650.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.projet.gui.patient.PatientConsultationController"
            style="-fx-background-color: #F2F0EC;">

    <!-- ═════════ TOP BAR ═════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: white;
                     -fx-padding: 20 30;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">

            <VBox spacing="3">
                <Label text="Espace Patient"
                       style="-fx-font-size: 22px; -fx-font-weight: 700; -fx-text-fill: #2D3748;"/>
                <Label text="Gérez vos consultations et réservations"
                       style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="⬅ Menu"
                    onAction="#retourMenu"
                    style="-fx-background-color: #E8956D;
                           -fx-text-fill: white;
                           -fx-font-weight: 600;
                           -fx-padding: 8 18;
                           -fx-background-radius: 8;"/>
        </HBox>
    </top>

    <!-- ═════════ SIDEBAR ═════════ -->
    <left>
        <VBox prefWidth="240"
              style="-fx-background-color: linear-gradient(to bottom, #3A5A90, #2E4A7A);
                     -fx-padding: 30 20;
                     -fx-spacing: 20;">

            <Label text="🧠"
                   style="-fx-font-size: 40px;"
                   alignment="CENTER"
                   maxWidth="Infinity"/>

            <Label text="EchoCare"
                   style="-fx-font-size: 18px;
                          -fx-font-weight: 700;
                          -fx-text-fill: white;"
                   alignment="CENTER"
                   maxWidth="Infinity"/>

            <Separator style="-fx-background-color: rgba(255,255,255,0.2);"/>

            <Button text="📋  Mes consultations"
                    onAction="#showConsultationsView"
                    maxWidth="Infinity"
                    alignment="CENTER_LEFT"
                    style="-fx-background-color: rgba(255,255,255,0.15);
                           -fx-text-fill: white;
                           -fx-padding: 12 15;
                           -fx-background-radius: 8;"/>

            <Button text="👨‍⚕️  Liste des psychologues"
                    onAction="#showPsyView"
                    maxWidth="Infinity"
                    alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: rgba(255,255,255,0.8);
                           -fx-padding: 12 15;
                           -fx-background-radius: 8;"/>

        </VBox>
    </left>

    <!-- ═════════ MAIN CONTENT ═════════ -->
    <center>
        <VBox spacing="25" style="-fx-padding: 30;">

            <!-- ═════ TITLE ═════ -->
            <Label fx:id="labelTitre"
                   text="Mes consultations"
                   style="-fx-font-size: 20px;
                          -fx-font-weight: 700;
                          -fx-text-fill: #2D3748;"/>

            <!-- ═════ TABLE CARD ═════ -->
            <VBox spacing="15"
                  style="-fx-background-color: white;
                         -fx-padding: 25;
                         -fx-background-radius: 14;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);">

                <TableView fx:id="tableConsultations"
                           prefHeight="350"
                           style="-fx-background-radius: 10; -fx-border-radius: 10;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
                        <TableColumn fx:id="colPsy" text="Psychologue" prefWidth="250"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="250"/>
                        <TableColumn fx:id="colStatut" text="Statut" prefWidth="200"/>
                    </columns>
                </TableView>

                <!-- Cancel Button -->
                <HBox fx:id="paneAnnuler" alignment="CENTER_RIGHT">
                    <Button text="🗑 Annuler consultation"
                            onAction="#handleCancelConsultation"
                            style="-fx-background-color: #E8956D;
                                   -fx-text-fill: white;
                                   -fx-font-weight: 600;
                                   -fx-padding: 8 18;
                                   -fx-background-radius: 8;"/>
                </HBox>

            </VBox>

            <!-- ═════ RESERVATION CARD ═════ -->
            <VBox fx:id="paneReservation" spacing="15" visible="false"
                  style="-fx-background-color: white;
                         -fx-padding: 25;
                         -fx-background-radius: 14;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);">

                <Label text="Réserver avec le psychologue sélectionné"
                       style="-fx-font-weight: 700; -fx-text-fill: #2D3748;"/>

                <HBox spacing="15">
                    <DatePicker fx:id="dateRes"
                                promptText="Date"
                                style="-fx-background-radius: 8;"/>

                    <TextField fx:id="heureRes"
                               promptText="Heure (ex: 15:30)"
                               style="-fx-background-color: #F6F3F0;
                                      -fx-border-color: #D5E3F5;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 8 12;"/>

                    <Button text="✓ Confirmer"
                            onAction="#confirmBooking"
                            style="-fx-background-color: #6BCB77;
                                   -fx-text-fill: white;
                                   -fx-font-weight: 600;
                                   -fx-background-radius: 8;
                                   -fx-padding: 8 18;"/>
                </HBox>

            </VBox>

        </VBox>
    </center>

</BorderPane>