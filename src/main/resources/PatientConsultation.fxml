<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.projet.gui.patient.PatientConsultationController">

    <children>

        <Label layoutX="260.0" layoutY="20.0"
               text="Mes consultations"
               style="-fx-font-size: 20px; -fx-font-weight: bold;" />

        <TableView fx:id="tableConsultations"
                   layoutX="50.0" layoutY="70.0"
                   prefWidth="600.0" prefHeight="300.0">

            <columns>

                <TableColumn fx:id="colId" text="ID" prefWidth="80.0"/>
                <TableColumn fx:id="colPsy" text="Psychologue" prefWidth="150.0"/>
                <TableColumn fx:id="colDate" text="Date" prefWidth="200.0"/>
                <TableColumn fx:id="colStatut" text="Statut" prefWidth="150.0"/>

            </columns>
        </TableView>

        <Button text="Actualiser"
                layoutX="300.0" layoutY="400.0"
                onAction="#handleRefresh"/>

    </children>
</AnchorPane>
