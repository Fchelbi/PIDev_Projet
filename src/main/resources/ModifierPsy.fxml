<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0" prefWidth="350.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.projet.gui.patient.ModifierPsyController">
    <children>
        <Label text="Modifier les informations" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
        <TextField fx:id="txtNom" promptText="Nom" />
        <TextField fx:id="txtPrenom" promptText="Prénom" />
        <TextField fx:id="txtEmail" promptText="Email" />
        <TextField fx:id="txtSpecialite" promptText="Spécialité" />
        <HBox spacing="10" alignment="CENTER">
            <Button text="Enregistrer" onAction="#handleSave" style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
        </HBox>
    </children>
    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>
</VBox>