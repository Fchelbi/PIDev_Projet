<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.projet.gui.patient.AdminPsyController">
    <children>
        <HBox spacing="20.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
            <children>
                <VBox spacing="10.0" prefWidth="250.0">
                    <children>
                        <Label text="Gestion des Psychologues" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                        <TextField fx:id="txtNom" promptText="Nom" />
                        <TextField fx:id="txtPrenom" promptText="Prénom" />
                        <TextField fx:id="txtEmail" promptText="Email" />
                        <TextField fx:id="txtSpecialite" promptText="Spécialité" />
            <Button onAction="#handleAjouter" text="Ajouter" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
            <Button onAction="#handleModifier" text="Modifier" style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
            <Button onAction="#handleSupprimer" text="Supprimer" style="-fx-background-color: #f44336; -fx-text-fill: white;" />
                    </children>
                    <padding>
                        <Insets top="20.0" />
                    </padding>
                </VBox>

                <TableView fx:id="tablePsys" HBox.hgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNom" prefWidth="100.0" text="Nom" />
                        <TableColumn fx:id="colPrenom" prefWidth="100.0" text="Prénom" />
                        <TableColumn fx:id="colEmail" prefWidth="150.0" text="Email" />
                        <TableColumn fx:id="colSpecialite" prefWidth="100.0" text="Spécialité" />
                    </columns>
                </TableView>
            </children>
        </HBox>
    </children>
    <Button text="⬅ Retour au Menu" onAction="#retourMenu"
            style="-fx-background-color: #607D8B; -fx-text-fill: white;"
            AnchorPane.topAnchor="10.0" AnchorPane.leftAnchor="10.0" />
</AnchorPane>